---
import SectionTitle from './SectionTitle.astro';
import PostCard from './PostCard.astro';
import EmptyState from './EmptyState.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<section class="section" id="latest-posts">
  <div class="container">
    <div class="archive-toolbar">
      <SectionTitle title="最新文章" description="持续更新技术写作、项目记录与思考总结。" />
      <div class="hero-actions">
        <a class="button" href="/archive">归档</a>
        <a class="button" href="/search">搜索</a>
      </div>
    </div>
    {posts.length > 0 ? (
      <div class="post-list">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <EmptyState title="当前还没有文章" description="发布文章后，这里会自动展示最新更新内容。" />
    )}
  </div>
</section>
