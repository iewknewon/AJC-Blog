---
import SectionTitle from './SectionTitle.astro';
import { siteConfig } from '../data/site';
---

<section class="section">
  <div class="container">
    <SectionTitle title="联系方式" description="如果你想交流技术、项目或写作相关内容，可以通过下面的方式联系我。" />
    <div class="grid two">
      <div class="contact-card">
        <h3>邮箱</h3>
        <p><a href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a></p>
      </div>
      <div class="contact-card">
        <h3>GitHub</h3>
        <p><a href={siteConfig.contact.github} target="_blank" rel="noreferrer">查看 GitHub 主页</a></p>
      </div>
    </div>
  </div>
</section>
