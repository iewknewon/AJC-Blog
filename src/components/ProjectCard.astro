---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="card project-card">
  <div class="project-card-head">
    <span class="section-kicker">Featured Build</span>
  </div>
  <h3 class="project-card-title">
    <a href={`/projects/${project.slug}/`}>{project.title}</a>
  </h3>
  <p class="muted project-card-description">{project.description}</p>
  <div class="tech-list project-card-tech">
    {project.techStack.map((item) => (
      <span class="tech-item">{item}</span>
    ))}
  </div>
  {project.highlights.length ? (
    <div class="project-card-highlights">
      {project.highlights.slice(0, 3).map((item) => (
        <p class="project-card-highlight">{item}</p>
      ))}
    </div>
  ) : null}
  <div class="hero-actions project-card-actions" style="margin-top: 1rem;">
    <a class="button button-primary" href={`/projects/${project.slug}/`}>查看详情</a>
    {project.demoUrl && (
      <a class="button" href={project.demoUrl} target="_blank" rel="noreferrer">在线演示</a>
    )}
    {project.repoUrl && (
      <a class="button" href={project.repoUrl} target="_blank" rel="noreferrer">仓库</a>
    )}
  </div>
</article>
