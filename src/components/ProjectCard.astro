---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="card">
  <h3>
    <a href={`/projects/${project.slug}/`}>{project.title}</a>
  </h3>
  <p class="muted">{project.description}</p>
  <div class="tech-list">
    {project.techStack.map((item) => (
      <span class="tech-item">{item}</span>
    ))}
  </div>
  <div class="hero-actions" style="margin-top: 1rem;">
    <a class="button button-primary" href={`/projects/${project.slug}/`}>查看详情</a>
    {project.demoUrl && (
      <a class="button" href={project.demoUrl} target="_blank" rel="noreferrer">在线演示</a>
    )}
    {project.repoUrl && (
      <a class="button" href={project.repoUrl} target="_blank" rel="noreferrer">仓库</a>
    )}
  </div>
</article>
