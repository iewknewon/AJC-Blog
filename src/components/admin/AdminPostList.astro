---
import EmptyState from '../EmptyState.astro';
import AdminStatusBadge from './AdminStatusBadge.astro';
import { formatDate } from '../../utils/format';
import type { BlogPost } from '../../lib/posts/types';

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
---

{posts.length > 0 ? (
  <div class="admin-table-wrapper card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>标题</th>
          <th>Slug</th>
          <th>状态</th>
          <th>更新时间</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        {posts.map((post) => (
          <tr>
            <td>
              <strong>{post.title}</strong>
            </td>
            <td>{post.slug}</td>
            <td><AdminStatusBadge status={post.status} /></td>
            <td>{formatDate(post.updatedAt)}</td>
            <td>
              <div class="hero-actions" style="margin-top: 0;">
                <a class="button" href={`/admin/posts/${post.id}`}>编辑</a>
                {post.status === 'published' ? <a class="button" href={`/blog/${post.slug}/`} target="_blank" rel="noreferrer">查看</a> : null}
                <form class="inline-form" action={`/api/admin/posts/${post.id}`} method="post" onsubmit="return confirm('确认删除这篇文章吗？此操作不可恢复。')">
                  <input type="hidden" name="intent" value="delete" />
                  <button class="button button-danger" type="submit">删除</button>
                </form>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
) : (
  <EmptyState title="还没有文章" description="先创建第一篇文章，保存草稿或直接发布。" />
)}
