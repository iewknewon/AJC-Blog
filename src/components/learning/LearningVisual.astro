---
import type { LearningAnimationKind } from '../../data/learning/types';
import ProtocolStackExplorer from './ProtocolStackExplorer.astro';
import RequestLifecycleAnimation from './RequestLifecycleAnimation.astro';
import TcpFlowAnimator from './TcpFlowAnimator.astro';
import SystemArchitectureMap from './SystemArchitectureMap.astro';
import InstructionCycleExplorer from './InstructionCycleExplorer.astro';
import CacheLocalityDemo from './CacheLocalityDemo.astro';
import AiAgentLandscape from './AiAgentLandscape.astro';
import SkillToolFunctionMap from './SkillToolFunctionMap.astro';
import McpFlowExplorer from './McpFlowExplorer.astro';
import WorkflowAgentComparator from './WorkflowAgentComparator.astro';
import MemoryContextExplorer from './MemoryContextExplorer.astro';
import RagPipelineExplorer from './RagPipelineExplorer.astro';
import GuardrailsObservabilityBoard from './GuardrailsObservabilityBoard.astro';
import ReverseLandscapeMap from './ReverseLandscapeMap.astro';
import PeAnatomyExplorer from './PeAnatomyExplorer.astro';
import RegisterFlowDemo from './RegisterFlowDemo.astro';
import DebuggerFlowBoard from './DebuggerFlowBoard.astro';
import MemoryStackFrameExplorer from './MemoryStackFrameExplorer.astro';
import ReverseCaseTraceBoard from './ReverseCaseTraceBoard.astro';

interface Props {
  kind: LearningAnimationKind;
}

const { kind } = Astro.props;
---

{kind === 'protocol-stack' ? <ProtocolStackExplorer /> : null}
{kind === 'http-lifecycle' ? <RequestLifecycleAnimation /> : null}
{kind === 'tcp-flow' ? <TcpFlowAnimator /> : null}
{kind === 'system-architecture' ? <SystemArchitectureMap /> : null}
{kind === 'instruction-cycle' ? <InstructionCycleExplorer /> : null}
{kind === 'cache-locality' ? <CacheLocalityDemo /> : null}
{kind === 'ai-agent-landscape' ? <AiAgentLandscape /> : null}
{kind === 'skill-tool-function' ? <SkillToolFunctionMap /> : null}
{kind === 'mcp-flow' ? <McpFlowExplorer /> : null}
{kind === 'workflow-vs-agent' ? <WorkflowAgentComparator /> : null}
{kind === 'memory-context' ? <MemoryContextExplorer /> : null}
{kind === 'rag-pipeline' ? <RagPipelineExplorer /> : null}
{kind === 'guardrails-observability' ? <GuardrailsObservabilityBoard /> : null}
{kind === 'reverse-landscape' ? <ReverseLandscapeMap /> : null}
{kind === 'pe-anatomy' ? <PeAnatomyExplorer /> : null}
{kind === 'register-flow' ? <RegisterFlowDemo /> : null}
{kind === 'debugger-flow' ? <DebuggerFlowBoard /> : null}
{kind === 'memory-stack-frame' ? <MemoryStackFrameExplorer /> : null}
{kind === 'reverse-case-trace' ? <ReverseCaseTraceBoard /> : null}
