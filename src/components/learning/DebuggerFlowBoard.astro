---
const phases = [
  {
    key: 'breakpoint',
    title: '下断点',
    summary: '先选一个值得停住的位置，而不是把程序每一步都掰开。',
    detail: '好的断点往往贴着你的假设：按钮事件、关键比较、可疑函数入口、导入 API 附近。',
    checks: ['为什么停这里', '停住后先看什么'],
  },
  {
    key: 'trigger',
    title: '触发动作',
    summary: '让程序走到你关心的场景里，观察断点是否按预期命中。',
    detail: '输入、点击、文件操作或网络请求都可以成为“触发器”，关键是让流程进入你怀疑的那条路径。',
    checks: ['动作是否能复现', '是否命中了预期位置'],
  },
  {
    key: 'step',
    title: '短距离单步',
    summary: '在最关键的几步里看寄存器、比较和跳转如何变化。',
    detail: '别把单步变成苦力活。只在关键几步细看，确认参数、标志位或分支条件，然后再继续运行。',
    checks: ['寄存器有何变化', '分支为何这样走'],
  },
  {
    key: 'stack',
    title: '回看调用栈',
    summary: '别忘了问“我是从哪来的，上层流程在做什么”。',
    detail: '调用栈能帮助你把当前一小段指令放回业务流程里，避免一直困在底层 API 周围。',
    checks: ['谁调用了它', '上层目标是什么'],
  },
] as const;
---

<div class="content-card learning-visual-card debugger-flow-card" data-learning-visual="debugger-flow">
  <div class="learning-visual-header">
    <div>
      <p class="eyebrow">Interactive Visual</p>
      <h3 class="section-title" style="font-size: 1.35rem;">调试流程板</h3>
    </div>
    <p class="muted">把调试当成四段动作，而不是“打开工具后随便点”。</p>
  </div>

  <div class="debugger-flow-track">
    {phases.map((phase, index) => (
      <button class:list={['debugger-flow-step', index === 0 && 'is-active']} type="button" data-debugger-phase={phase.key}>
        <span>{String(index + 1).padStart(2, '0')}</span>
        <strong>{phase.title}</strong>
        <small>{phase.summary}</small>
      </button>
    ))}
  </div>

  <div class="debugger-flow-panel">
    <p class="learning-stack-caption">这一段最该问自己的问题</p>
    <h4 data-debugger-title>{phases[0].title}</h4>
    <p data-debugger-detail>{phases[0].detail}</p>
    <div class="learning-stack-tags">
      {phases[0].checks.map((item, index) => (
        <span class="tag" data-debugger-check={index}>{item}</span>
      ))}
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-learning-visual="debugger-flow"]');

    if (!root) {
      return;
    }

    const phaseMap = {
      breakpoint: {
        title: '下断点',
        detail: '好的断点往往贴着你的假设：按钮事件、关键比较、可疑函数入口、导入 API 附近。',
        checks: ['为什么停这里', '停住后先看什么'],
      },
      trigger: {
        title: '触发动作',
        detail: '输入、点击、文件操作或网络请求都可以成为“触发器”，关键是让流程进入你怀疑的那条路径。',
        checks: ['动作是否能复现', '是否命中了预期位置'],
      },
      step: {
        title: '短距离单步',
        detail: '别把单步变成苦力活。只在关键几步细看，确认参数、标志位或分支条件，然后再继续运行。',
        checks: ['寄存器有何变化', '分支为何这样走'],
      },
      stack: {
        title: '回看调用栈',
        detail: '调用栈能帮助你把当前一小段指令放回业务流程里，避免一直困在底层 API 周围。',
        checks: ['谁调用了它', '上层目标是什么'],
      },
    };

    const buttons = Array.from(root.querySelectorAll('[data-debugger-phase]'));
    const title = root.querySelector('[data-debugger-title]');
    const detail = root.querySelector('[data-debugger-detail]');
    const checks = Array.from(root.querySelectorAll('[data-debugger-check]'));

    const applyPhase = (key) => {
      const phase = phaseMap[key];

      if (!phase) {
        return;
      }

      buttons.forEach((button) => {
        button.classList.toggle('is-active', button.dataset.debuggerPhase === key);
      });

      if (title) {
        title.textContent = phase.title;
      }

      if (detail) {
        detail.textContent = phase.detail;
      }

      checks.forEach((node, index) => {
        node.textContent = phase.checks[index] ?? '';
      });
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => applyPhase(button.dataset.debuggerPhase));
    });
  })();
</script>

<style>
  .debugger-flow-track {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .debugger-flow-step,
  .debugger-flow-panel {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
    text-align: left;
    border-radius: 20px;
    border: 1px solid color-mix(in srgb, var(--border) 78%, white 22%);
    background: color-mix(in srgb, var(--surface) 90%, white 10%);
    color: var(--text);
    font: inherit;
  }

  .debugger-flow-step {
    cursor: pointer;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .debugger-flow-step span,
  .debugger-flow-step small {
    color: var(--text-muted);
  }

  .debugger-flow-step.is-active {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, #2563eb 38%, var(--border) 62%);
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.12), rgba(15, 23, 42, 0.03));
  }

  .debugger-flow-panel h4 {
    margin: 0;
    font-size: 1.2rem;
    font-family: var(--display-font);
  }

  .debugger-flow-panel p {
    margin: 0;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .debugger-flow-track {
      grid-template-columns: 1fr;
    }
  }
</style>
