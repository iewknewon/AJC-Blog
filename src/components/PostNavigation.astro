---
import type { BlogPost } from '../lib/posts/types';

interface Props {
  previous?: BlogPost;
  next?: BlogPost;
}

const { previous, next } = Astro.props;
---

<div class="post-nav post-nav-editorial">
  {previous ? (
    <a class="content-card post-nav-card post-nav-card-editorial" href={`/blog/${previous.slug}/`}>
      <p class="meta">Previous</p>
      <h3>{previous.title}</h3>
      <p class="muted">Continue reading the previous article in the timeline.</p>
    </a>
  ) : (
    <div class="empty-state post-nav-card post-nav-card-editorial">
      <p>This is the earliest article.</p>
    </div>
  )}

  {next ? (
    <a class="content-card post-nav-card post-nav-card-editorial" href={`/blog/${next.slug}/`}>
      <p class="meta">Next</p>
      <h3>{next.title}</h3>
      <p class="muted">Continue to the next article update.</p>
    </a>
  ) : (
    <div class="empty-state post-nav-card post-nav-card-editorial">
      <p>This is the latest article.</p>
    </div>
  )}
</div>
