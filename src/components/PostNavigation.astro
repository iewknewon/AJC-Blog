---
import type { CollectionEntry } from 'astro:content';

interface Props {
  previous?: CollectionEntry<'blog'>;
  next?: CollectionEntry<'blog'>;
}

const { previous, next } = Astro.props;
---

<div class="post-nav">
  {previous ? (
    <a class="content-card" href={`/blog/${previous.slug}/`}>
      <p class="meta">上一篇</p>
      <h3>{previous.data.title}</h3>
    </a>
  ) : (
    <div class="empty-state">
      <p>已经是最早的一篇文章了。</p>
    </div>
  )}

  {next ? (
    <a class="content-card" href={`/blog/${next.slug}/`}>
      <p class="meta">下一篇</p>
      <h3>{next.data.title}</h3>
    </a>
  ) : (
    <div class="empty-state">
      <p>已经是最新的一篇文章了。</p>
    </div>
  )}
</div>
