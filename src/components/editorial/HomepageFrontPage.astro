---
import { formatDate } from '../../utils/format';

type FrontPagePost = {
  slug: string;
  title: string;
  description: string;
  publishedAt: Date | null;
  updatedAt: Date;
  tags?: string[];
};

type FrontPageSubject = {
  slug: string;
  title: string;
  description: string;
};

type FrontPageProject = {
  slug: string;
  title: string;
  description: string;
};

type HomepageEdition = {
  leadPost: FrontPagePost | null;
  secondaryPosts: FrontPagePost[];
  latestPosts: FrontPagePost[];
  learningSubjects: FrontPageSubject[];
  featuredProjects: FrontPageProject[];
};

interface Props {
  edition: HomepageEdition;
  editorNote: string;
}

const { edition, editorNote } = Astro.props;
const leadDate = edition.leadPost ? formatDate(edition.leadPost.publishedAt ?? edition.leadPost.updatedAt) : null;
---

<section class="front-page">
  <div class="container">
    <div class="front-page-grid">
      <aside class="front-page-note">
        <p class="front-page-note-label">Editor&apos;s Note</p>
        <p>{editorNote}</p>
      </aside>

      <div>
        <p class="front-page-overline">Front Page Edition</p>
        {edition.leadPost ? (
          <article class="front-page-lead">
            <h2 class="front-page-lead-title">
              <a href={`/blog/${edition.leadPost.slug}/`}>{edition.leadPost.title}</a>
            </h2>
            <p class="front-page-lead-deck">{edition.leadPost.description}</p>
            <div class="front-page-meta-row">
              <span>{leadDate}</span>
              <span>{edition.leadPost.tags?.[0] ?? 'Top Story'}</span>
            </div>
          </article>
        ) : (
          <section class="front-page-section">
            <p class="front-page-section-label">Lead Story</p>
            <p>The newsroom is preparing the next lead story.</p>
          </section>
        )}
      </div>

      <aside class="front-page-rail">
        <p class="front-page-rail-label">Latest</p>
        <ul class="front-page-rail-list">
          {edition.latestPosts.length ? (
            edition.latestPosts.map((post) => (
              <li>
                <a href={`/blog/${post.slug}/`}>{post.title}</a>
              </li>
            ))
          ) : (
            <li>No recent dispatches yet.</li>
          )}
        </ul>
      </aside>
    </div>

    <div class="front-page-sections">
      <section class="front-page-section">
        <p class="front-page-section-label">Secondary Stories</p>
        <ul class="front-page-story-list">
          {edition.secondaryPosts.length ? (
            edition.secondaryPosts.map((post) => (
              <li>
                <a href={`/blog/${post.slug}/`}>{post.title}</a>
              </li>
            ))
          ) : (
            <li>No secondary stories yet.</li>
          )}
        </ul>
      </section>

      <section class="front-page-section">
        <p class="front-page-section-label">Latest Dispatches</p>
        <ul class="front-page-story-list">
          {edition.latestPosts.length ? (
            edition.latestPosts.map((post) => (
              <li>
                <a href={`/blog/${post.slug}/`}>{post.title}</a>
              </li>
            ))
          ) : (
            <li>No latest stories yet.</li>
          )}
        </ul>
      </section>

      <section class="front-page-section">
        <p class="front-page-section-label">Cross Desk Briefing</p>
        <div class="front-page-mini-grid">
          <section>
            <h3>Learning</h3>
            <ul class="front-page-story-list">
              {edition.learningSubjects.length ? (
                edition.learningSubjects.map((subject) => (
                  <li>
                    <a href={`/learn/${subject.slug}`}>{subject.title}</a>
                  </li>
                ))
              ) : (
                <li>No learning subjects available.</li>
              )}
            </ul>
          </section>
          <section>
            <h3>Projects</h3>
            <ul class="front-page-story-list">
              {edition.featuredProjects.length ? (
                edition.featuredProjects.map((project) => (
                  <li>
                    <a href={`/projects/${project.slug}`}>{project.title}</a>
                  </li>
                ))
              ) : (
                <li>No featured projects available.</li>
              )}
            </ul>
          </section>
        </div>
      </section>
    </div>
  </div>
</section>
