---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const items = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

{items.length > 0 && (
  <aside class="content-card toc">
    <h3>文章目录</h3>
    <ul>
      {items.map((heading) => (
        <li style={`padding-left: ${(heading.depth - 2) * 1}rem`}>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ul>
  </aside>
)}
