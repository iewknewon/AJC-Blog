---
import SectionTitle from './SectionTitle.astro';
import PostCard from './PostCard.astro';
import EmptyState from './EmptyState.astro';
import type { BlogPost } from '../lib/posts/types';

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="archive-toolbar">
      <SectionTitle kicker="Editorial Picks" title="推荐文章" description="优先阅读这些文章，可以快速了解这个博客的内容方向。" />
      <a class="button" href="/archive">查看全部文章</a>
    </div>
    {posts.length > 0 ? (
      <div class="post-list">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <EmptyState title="当前没有推荐文章" description="等文章积累到一定数量后，这里会保留最值得先读的内容。" />
    )}
  </div>
</section>
