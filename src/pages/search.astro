---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { siteConfig } from '../data/site';
import { serializeInlineJson } from '../lib/utils/inline-json';
import { formatDate } from '../utils/format';
import { getPublishedPosts, renderPost } from '../utils/posts';

const db = Astro.locals.runtime.env.DB;
const posts = await getPublishedPosts(db);
const renderedPosts = await Promise.all(posts.map((post) => renderPost(post)));
const searchIndex = renderedPosts.map((post) => ({
  slug: post.slug,
  title: post.title,
  description: post.description,
  tags: post.tags,
  date: formatDate(post.publishedAt ?? post.updatedAt),
  content: post.plainText,
}));
---

<BaseLayout title={`搜索 | ${siteConfig.title}`} description="按标题、摘要、标签和正文搜索文章。" pathname="/search">
  <section class="section">
    <div class="container">
      <PageHero
        kicker="Search"
        title="搜索文章"
        description="按标题、摘要、标签和正文关键词快速检索内容，适合回看以前的实践记录。"
        actions={[
          { href: '/archive', label: '浏览归档' },
          { href: '/tags', label: '按标签查看' },
        ]}
        stats={[
          { label: '收录范围', value: `${posts.length} 篇文章` },
          { label: '检索字段', value: '标题 / 摘要 / 标签 / 正文' },
        ]}
      />
      <div class="content-card search-shell">
        <form class="search-form search-form-panel" action="/search" method="get">
          <input id="search-input" class="search-input" type="search" name="q" placeholder="例如：Astro、Cloudflare、部署" />
          <button class="button button-primary" type="submit">搜索</button>
        </form>
        <p id="search-summary" class="muted search-summary">输入关键词开始搜索。</p>
      </div>
      <div id="search-results" class="post-list search-results-grid"></div>
      <noscript>
        <div class="search-results-grid">
          <div class="empty-state">搜索功能需要启用浏览器 JavaScript。</div>
        </div>
      </noscript>
    </div>
  </section>

  <script id="search-index" type="application/json" set:html={serializeInlineJson(searchIndex)}></script>
  <script is:inline>
    const input = document.querySelector('#search-input');
    const summary = document.querySelector('#search-summary');
    const results = document.querySelector('#search-results');
    const searchData = JSON.parse(document.querySelector('#search-index')?.textContent ?? '[]');

    const createTag = (tag) => {
      const element = document.createElement('a');
      element.className = 'tag';
      element.href = `/tags/${encodeURIComponent(tag)}/`;
      element.textContent = tag;
      return element;
    };

    const createCard = (post) => {
      const article = document.createElement('article');
      article.className = 'card post-card search-result-card';

      const coverLink = document.createElement('a');
      coverLink.className = 'post-card-cover-link is-placeholder';
      coverLink.href = `/blog/${post.slug}/`;

      const cover = document.createElement('div');
      cover.className = 'post-card-cover post-card-cover-placeholder';

      const coverLabel = document.createElement('span');
      coverLabel.textContent = post.tags[0] ?? 'Search';
      cover.append(coverLabel);
      coverLink.append(cover);

      const body = document.createElement('div');
      body.className = 'post-card-body search-result-card-body';

      const top = document.createElement('div');
      top.className = 'post-card-top';

      const meta = document.createElement('p');
      meta.className = 'meta post-card-meta';
      meta.textContent = post.date;

      const readmore = document.createElement('span');
      readmore.className = 'post-card-readmore';
      readmore.textContent = '查看文章';

      const heading = document.createElement('h3');
      heading.className = 'post-card-title';
      const link = document.createElement('a');
      link.href = `/blog/${post.slug}/`;
      link.textContent = post.title;
      heading.append(link);

      const description = document.createElement('p');
      description.className = 'muted post-card-description';
      description.textContent = post.description;

      const tags = document.createElement('div');
      tags.className = 'tags post-card-tags';
      post.tags.forEach((tag) => tags.append(createTag(tag)));

      top.append(meta, readmore);
      body.append(top, heading, description, tags);
      article.append(coverLink, body);
      return article;
    };

    const renderEmpty = (title, description) => {
      results.innerHTML = '';
      const wrapper = document.createElement('div');
      wrapper.className = 'empty-state';

      const heading = document.createElement('h3');
      heading.textContent = title;
      const text = document.createElement('p');
      text.className = 'muted';
      text.textContent = description;

      wrapper.append(heading, text);
      results.append(wrapper);
    };

    const render = (keyword) => {
      const normalizedKeyword = keyword.trim().toLowerCase();
      input.value = keyword;

      if (!normalizedKeyword) {
        summary.textContent = '输入关键词开始搜索。';
        renderEmpty('输入关键词开始搜索', '推荐先试试 Astro、Cloudflare、Markdown、部署 这些词。');
        return;
      }

      const matched = searchData.filter((post) => {
        const searchableText = [post.title, post.description, ...post.tags, post.content].join(' ').toLowerCase();
        return searchableText.includes(normalizedKeyword);
      });

      results.innerHTML = '';

      if (matched.length === 0) {
        summary.textContent = `没有找到与“${keyword}”相关的文章`;
        renderEmpty('没有找到匹配文章', '你可以尝试更短的关键词，或者先去归档页浏览全部文章。');
        return;
      }

      summary.textContent = `共找到 ${matched.length} 篇与“${keyword}”相关的文章`;
      matched.forEach((post) => results.append(createCard(post)));
    };

    const params = new URLSearchParams(window.location.search);
    render(params.get('q') ?? '');
  </script>
</BaseLayout>
