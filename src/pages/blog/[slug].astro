---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import PostNavigation from '../../components/PostNavigation.astro';
import EmptyState from '../../components/EmptyState.astro';
import { siteConfig } from '../../data/site';
import { getPublishedNovelChapterRouteByPostSlug } from '../../lib/novels/repository';
import { formatDate, getReadingTime } from '../../utils/format';
import { getNovelChapterUrl } from '../../utils/novels';
import { getAdjacentPosts, getPublishedPostBySlug, getPublishedPosts, renderPost } from '../../utils/posts';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/archive');
}

const db = Astro.locals.runtime?.env?.DB;
const novelChapterRoute = db ? await getPublishedNovelChapterRouteByPostSlug(db, slug) : null;

if (novelChapterRoute) {
  return Astro.redirect(
    getNovelChapterUrl(
      novelChapterRoute.projectSlug,
      novelChapterRoute.volumeNumber,
      novelChapterRoute.chapterNumber,
    ),
  );
}

const post = db ? await getPublishedPostBySlug(db, slug) : null;

if (db && !post) {
  return Astro.redirect('/404');
}

const renderedPost = post ? await renderPost(post) : null;
const posts = db ? await getPublishedPosts(db) : [];
const adjacentPosts = post ? getAdjacentPosts(posts, post.slug) : { previous: undefined, next: undefined };
const readingTime = renderedPost ? getReadingTime(renderedPost.plainText) : '';
const publishDate = post ? (post.publishedAt ?? post.updatedAt) : null;
---

<BaseLayout
  title={post ? `${post.title} | ${siteConfig.title}` : `Article | ${siteConfig.title}`}
  description={post?.description ?? 'Article content is unavailable in the current environment.'}
  pathname={post ? `/blog/${post.slug}/` : `/blog/${slug}/`}
>
  {post && renderedPost && publishDate ? (
    <div class="container article-layout-editorial">
      <article class="article-shell article-shell-editorial">
        <header class="article-header">
          <p class="article-kicker">TECHNICAL ARTICLE</p>
          <h1 class="article-headline">{post.title}</h1>
          <p class="article-deck">{post.description}</p>
          <div class="article-meta-strip tags">
            <span class="tag">{formatDate(publishDate)}</span>
            <span class="tag">{readingTime}</span>
            {post.tags.map((tag) => (
              <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
            ))}
          </div>
        </header>

        {post.cover ? (
          <figure class="article-cover article-cover-editorial">
            <img src={post.cover} alt={`${post.title} cover`} loading="eager" decoding="async" />
          </figure>
        ) : null}

        <div class="article-utility-bar hero-actions">
          <a class="button" href={`/blog/${post.slug}/wechat/`}>Export for WeChat</a>
          <a class="button" href="/archive">Back to Archive</a>
        </div>

        <div class="article-content article-content-editorial" set:html={renderedPost.html}></div>

        <div class="content-card" style="margin-top: 2rem;">
          <h3>Continue Reading</h3>
          <p class="muted">
            Explore the archive, browse by tags, or jump to projects for more related writing.
          </p>
          <div class="hero-actions" style="margin-top: 1rem;">
            <a class="button" href="/archive">Browse Archive</a>
            <a class="button" href="/tags">View Tags</a>
            <a class="button" href="/projects">View Projects</a>
          </div>
        </div>

        <PostNavigation previous={adjacentPosts.previous} next={adjacentPosts.next} />
      </article>
      <TableOfContents headings={renderedPost.headings} />
    </div>
  ) : (
    <section class="section">
      <div class="container">
        <EmptyState
          title="Article content unavailable"
          description="The content database is not connected in this environment. The page will recover automatically once data is available."
        />
      </div>
    </section>
  )}
</BaseLayout>
