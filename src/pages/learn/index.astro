---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import LearningSubjectCard from '../../components/learning/LearningSubjectCard.astro';
import { siteConfig } from '../../data/site';
import { getLearningSubjects } from '../../lib/learning/content';

const subjects = getLearningSubjects();
const lessonCount = subjects.reduce((total, subject) => total + subject.lessons.length, 0);
---

<BaseLayout title={`学习中心 | ${siteConfig.title}`} description="用更通俗、更可视化的方式学习计算机网络、计算机组成原理和 AI / Agent 工程基础。" pathname="/learn">
  <section class="section">
    <div class="container">
      <PageHero
        kicker="Learning Center"
        title="公开学习中心"
        description="这里不只放文章，而是把抽象概念拆成可直观看懂的课时：从计算机网络、计算机组成原理，到 AI / Agent 工程基础，都尽量讲到“看完就能解释给别人听”。"
        actions={[
          { href: '/learn/ai-agent-engineering', label: '看 AI 工程', primary: true },
          { href: '/learn/networking', label: '从网络开始' },
          { href: '/learn/computer-organization', label: '看组成原理' },
        ]}
        stats={[
          { label: '学习专题', value: `${subjects.length} 条` },
          { label: '首发课时', value: `${lessonCount} 节` },
        ]}
      />

      <div class="grid two learning-subject-grid">
        {subjects.map((subject) => (
          <LearningSubjectCard subject={subject} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
