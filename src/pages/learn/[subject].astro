---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import LearningLessonCard from '../../components/learning/LearningLessonCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import { siteConfig } from '../../data/site';
import { getMergedLearningSubjectBySlug } from '../../lib/learning/content';

const db = Astro.locals.runtime?.env?.DB;
const subjectSlug = Astro.params.subject ?? '';
const currentSubject = subjectSlug ? await getMergedLearningSubjectBySlug(subjectSlug, db) : null;

if (!currentSubject) {
  return Astro.redirect('/learn');
}

const sortedLessons = [...currentSubject.lessons].sort((left, right) => left.order - right.order);
const firstLesson = sortedLessons[0];
const isTimelineSubject = currentSubject.pageVariant === 'timeline';
const conceptOverview = currentSubject.conceptOverview;
---

<BaseLayout title={`${currentSubject.title} | 学习中心 | ${siteConfig.title}`} description={currentSubject.description} pathname={`/learn/${currentSubject.slug}`}>
  <section class="section">
    <div class="container">
      <PageHero
        kicker={currentSubject.eyebrow}
        title={currentSubject.title}
        description={currentSubject.description}
        actions={[
          { href: '/learn', label: '返回学习中心' },
          firstLesson
            ? { href: `/learn/${currentSubject.slug}/${firstLesson.lessonSlug}`, label: '开始第一课', primary: true }
            : { href: '/learn', label: '查看其它专题', primary: true },
        ]}
        stats={[
          { label: '课时数', value: `${sortedLessons.length}` },
          { label: '学习方式', value: isTimelineSubject ? '概念总览 + 学习轴' : '学习路径 + 课时列表' },
        ]}
      />

      {conceptOverview ? (
        <section class="content-card learning-overview-card">
          <div class="learning-overview-main">
            <p class="eyebrow">Concept Overview</p>
            <h2 class="section-title">{conceptOverview.title}</h2>
            <p class="section-description">{conceptOverview.summary}</p>
          </div>
          <div class="grid two">
            <article class="content-card learning-overview-subcard">
              <h3 class="section-title" style="font-size: 1.1rem;">这条线会重点讲什么</h3>
              <div class="learning-objectives-list">
                {conceptOverview.pillars.map((item) => (
                  <p class="learning-objective-item">{item}</p>
                ))}
              </div>
            </article>
            <article class="content-card learning-overview-subcard">
              <h3 class="section-title" style="font-size: 1.1rem;">边界与提醒</h3>
              <div class="learning-objectives-list">
                {conceptOverview.safetyNotes.map((item) => (
                  <p class="learning-objective-item">{item}</p>
                ))}
              </div>
            </article>
          </div>
        </section>
      ) : null}

      {!isTimelineSubject ? (
        <section class="content-card" style="margin-top: 1.5rem;">
          <h2 class="section-title" style="font-size: 1.3rem;">学习路径</h2>
          <div class="learning-path-list">
            {currentSubject.learningPath.map((item, index) => (
              <p class="learning-path-item">
                <strong>Step {index + 1}.</strong> {item}
              </p>
            ))}
          </div>
        </section>
      ) : null}

      {sortedLessons.length > 0 ? (
        isTimelineSubject ? (
          <section class="learning-timeline-list learning-timeline-axis">
            {sortedLessons.map((lesson) => (
              <article class="content-card learning-timeline-node">
                <div class="learning-timeline-number">{String(lesson.order).padStart(2, '0')}</div>
                <div class="learning-timeline-body">
                  <p class="eyebrow">Lesson {lesson.order}</p>
                  <h2 class="section-title" style="font-size: 1.35rem;">{lesson.title}</h2>
                  <p class="section-description">{lesson.description}</p>
                  <div class="tags" style="margin-top: 0.35rem;">
                    <span class="tag">{lesson.estimatedMinutes} 分钟</span>
                    {lesson.keywords.slice(0, 3).map((keyword) => (
                      <span class="tag">{keyword}</span>
                    ))}
                  </div>
                  <div class="hero-actions" style="margin-top: 0.75rem;">
                    <a class="button button-primary" href={`/learn/${currentSubject.slug}/${lesson.lessonSlug}`}>进入这节课</a>
                  </div>
                </div>
              </article>
            ))}
          </section>
        ) : (
          <div class="grid two learning-lesson-grid">
            {sortedLessons.map((lesson) => (
              <LearningLessonCard lesson={lesson} subjectTitle={currentSubject.title} />
            ))}
          </div>
        )
      ) : (
        <div style="margin-top: 1.5rem;">
          <EmptyState title="这个专题还没有课时" description="等后台生成或补充课时后，这里会自动展示。" />
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .learning-overview-card {
    margin-top: 1.5rem;
    display: grid;
    gap: 1rem;
  }

  .learning-overview-subcard {
    padding: 1rem;
    background: color-mix(in srgb, var(--surface-muted) 84%, white 16%);
    box-shadow: none;
  }

  .learning-timeline-list {
    position: relative;
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .learning-timeline-axis::before {
    content: '';
    position: absolute;
    left: 2.5rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: color-mix(in srgb, var(--brand) 26%, var(--border) 74%);
    opacity: 0.85;
  }

  .learning-timeline-node {
    position: relative;
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .learning-timeline-number {
    display: grid;
    place-items: center;
    min-height: 4.5rem;
    border-radius: 1rem;
    font-size: 1.4rem;
    font-weight: 700;
    background: color-mix(in srgb, var(--brand) 14%, var(--surface) 86%);
    color: var(--text);
  }

  .learning-timeline-body {
    display: grid;
    gap: 0.45rem;
  }

  @media (max-width: 720px) {
    .learning-timeline-axis::before {
      display: none;
    }

    .learning-timeline-node {
      grid-template-columns: 1fr;
    }
  }
</style>
