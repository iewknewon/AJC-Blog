---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import PostCard from '../../../components/PostCard.astro';
import { siteConfig } from '../../../data/site';
import { getPublishedPosts, paginatePosts } from '../../../utils/posts';

const db = Astro.locals.runtime.env.DB;
const posts = await getPublishedPosts(db);
const currentPage = Number(Astro.params.page);
const pagination = paginatePosts(posts, currentPage);
---

<BaseLayout
  title={`文章归档 - 第 ${pagination.currentPage} 页 | ${siteConfig.title}`}
  description="按时间顺序浏览全部文章。"
  pathname={`/archive/page/${pagination.currentPage}`}
>
  <section class="section">
    <div class="container">
      <PageHero
        kicker="Archive"
        title="文章归档"
        description="按时间倒序浏览站点内已经公开发布的文章，适合系统回看和连续阅读。"
        actions={[
          { href: '/search', label: '搜索文章', primary: true },
          { href: '/tags', label: '浏览标签' },
        ]}
        stats={[
          { label: '已发布文章', value: `${pagination.totalItems} 篇` },
          { label: '当前页码', value: `${pagination.currentPage} / ${pagination.totalPages}` },
        ]}
      />
      <div class="archive-list page-card-grid">
        {pagination.items.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
      <nav class="pagination">
        {pagination.currentPage > 1 ? (
          <a class="button" href={pagination.currentPage === 2 ? '/archive' : `/archive/page/${pagination.currentPage - 1}`}>
            上一页
          </a>
        ) : (
          <span class="button pagination-disabled">上一页</span>
        )}
        <span class="pagination-info">第 {pagination.currentPage} / {pagination.totalPages} 页</span>
        {pagination.currentPage < pagination.totalPages ? (
          <a class="button" href={`/archive/page/${pagination.currentPage + 1}`}>下一页</a>
        ) : (
          <span class="button pagination-disabled">下一页</span>
        )}
      </nav>
    </div>
  </section>
</BaseLayout>
