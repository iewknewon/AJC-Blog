---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PostCard from '../../components/PostCard.astro';
import { projects } from '../../data/projects';
import { siteConfig } from '../../data/site';
import { getPublishedPosts } from '../../utils/posts';
import { getRelatedPostsForProject } from '../../utils/projects.js';

const { slug } = Astro.params;
const project = projects.find((item) => item.slug === slug);

if (!project) {
  return Astro.redirect('/404');
}

const db = Astro.locals.runtime.env.DB;
const posts = await getPublishedPosts(db);
const relatedPosts = getRelatedPostsForProject(posts, project.relatedPostSlugs ?? []);
const projectActions = [];

if (project.demoUrl) {
  projectActions.push({ href: project.demoUrl, label: '查看演示', primary: true, external: true });
}

if (project.repoUrl) {
  projectActions.push({ href: project.repoUrl, label: '查看仓库', external: true });
}

projectActions.push({ href: '/projects', label: '返回项目列表' });
---

<BaseLayout title={`${project.title} | 项目详情 | ${siteConfig.title}`} description={project.description} pathname={`/projects/${project.slug}/`}>
  <section class="section">
    <div class="container">
      <PageHero
        kicker="Project Detail"
        title={project.title}
        description={project.description}
        actions={projectActions}
        stats={[
          { label: '技术栈', value: `${project.techStack.length} 项` },
          { label: '项目亮点', value: `${project.highlights.length} 条` },
        ]}
      />

      <div class="project-detail-grid">
        <div class="content-card">
          <h2 class="section-title">项目亮点</h2>
          <div class="project-card-highlights project-detail-highlights">
            {project.highlights.map((item) => (
              <p class="project-card-highlight">{item}</p>
            ))}
          </div>
        </div>
        <div class="content-card">
          <h2 class="section-title">技术构成</h2>
          <div class="tech-list">
            {project.techStack.map((item) => (
              <span class="tech-item">{item}</span>
            ))}
          </div>
          <p class="muted project-detail-note">这部分技术栈直接对应当前项目的实现结构和后续迭代方向。</p>
        </div>
      </div>

      <div class="content-card related-posts-panel">
        <h2 class="section-title">相关文章</h2>
        <p class="muted">如果你想继续了解这个项目背后的思路，可以从这些文章开始。</p>
        {relatedPosts.length > 0 ? (
          <div class="post-list page-card-grid">
            {relatedPosts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : (
          <p class="muted project-detail-note">这个项目暂时还没有关联文章，后续补充内容后会在这里更新。</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
