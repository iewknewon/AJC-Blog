---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { projects } from '../../data/projects';
import { siteConfig } from '../../data/site';
import { getPublishedPosts } from '../../utils/posts';
import { getRelatedPostsForProject } from '../../utils/projects.js';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const posts = await getPublishedPosts();
const relatedPosts = getRelatedPostsForProject(posts, project.relatedPostSlugs ?? []);
---

<BaseLayout title={`${project.title} | 项目详情 | ${siteConfig.title}`} description={project.description} pathname={`/projects/${project.slug}/`}>
  <section class="section">
    <div class="container">
      <div class="content-card">
        <p class="eyebrow">项目详情</p>
        <h1>{project.title}</h1>
        <p class="page-intro">{project.description}</p>
        <div class="tech-list">
          {project.techStack.map((item) => (
            <span class="tech-item">{item}</span>
          ))}
        </div>
        <div style="margin-top: 2rem;">
          <h2 class="section-title">项目亮点</h2>
          <ul>
            {project.highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
        <div class="hero-actions" style="margin-top: 2rem;">
          {project.demoUrl && (
            <a class="button button-primary" href={project.demoUrl} target="_blank" rel="noreferrer">查看演示</a>
          )}
          {project.repoUrl && (
            <a class="button" href={project.repoUrl} target="_blank" rel="noreferrer">查看仓库</a>
          )}
        </div>
      </div>

      <div class="content-card" style="margin-top: 1.5rem;">
        <h2 class="section-title">相关文章</h2>
        <p class="muted">如果你想继续了解这个项目背后的思路，可以从这些文章开始。</p>
        {relatedPosts.length > 0 ? (
          <div class="post-list" style="margin-top: 1.5rem;">
            {relatedPosts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : (
          <p class="muted" style="margin-top: 1rem;">这个项目暂时还没有关联文章，后续补充内容后会在这里更新。</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
