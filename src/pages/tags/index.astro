---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import EmptyState from '../../components/EmptyState.astro';
import { siteConfig } from '../../data/site';
import { getAllTags } from '../../utils/posts';

const tags = await getAllTags();
---

<BaseLayout title={`标签 | ${siteConfig.title}`} description="浏览博客中的所有标签。" pathname="/tags">
  <section class="section">
    <div class="container">
      <SectionTitle title="全部标签" description="通过标签快速找到你感兴趣的内容主题。" />
      {tags.length > 0 ? (
        <div class="grid three">
          {tags.map((tag) => (
            <a class="tag-card" href={`/tags/${encodeURIComponent(tag.name)}/`}>
              <h3>{tag.name}</h3>
              <p class="muted">共 {tag.count} 篇文章</p>
            </a>
          ))}
        </div>
      ) : (
        <EmptyState title="暂无标签" description="当前还没有可展示的标签。" />
      )}
    </div>
  </section>
</BaseLayout>
