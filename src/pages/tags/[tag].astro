---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PostCard from '../../components/PostCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import { siteConfig } from '../../data/site';
import { getPostsByTag } from '../../utils/posts';

const { tag } = Astro.params;

if (!tag) {
  return Astro.redirect('/tags');
}

const db = Astro.locals.runtime.env.DB;
const posts = await getPostsByTag(db, tag);
---

<BaseLayout title={`${tag} | 标签 | ${siteConfig.title}`} description={`查看标签 ${tag} 下的全部文章。`} pathname={`/tags/${encodeURIComponent(tag)}/`}>
  <section class="section">
    <div class="container">
      <PageHero
        kicker="Topic"
        title={`标签：${tag}`}
        description={`这里收录了所有与“${tag}”相关的文章。`}
        actions={[
          { href: '/tags', label: '返回标签总览' },
          { href: '/search', label: '继续搜索', primary: true },
        ]}
        stats={[
          { label: '相关文章', value: `${posts.length} 篇` },
        ]}
      />
      {posts.length > 0 ? (
        <div class="post-list page-card-grid">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <div style="margin-top: 2rem;">
          <EmptyState title="这个标签下还没有文章" description="你可以先返回标签总览，看看其他主题。" />
        </div>
      )}
    </div>
  </section>
</BaseLayout>
