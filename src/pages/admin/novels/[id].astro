---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminNovelForm from '../../../components/admin/AdminNovelForm.astro';
import { serializeInlineJson } from '../../../lib/utils/inline-json';
import { isAdminAuthenticated } from '../../../lib/auth/guards';
import {
  getNovelChaptersByProjectId,
  getNovelProjectById,
  getNovelReferenceSources,
} from '../../../lib/novels/repository';
import { getNextNovelChapterPosition } from '../../../lib/ai/novels';
import { getNovelChapterUrl } from '../../../utils/novels';

const authenticated = await isAdminAuthenticated(Astro.cookies, Astro.locals.runtime?.env);

if (!authenticated) {
  return Astro.redirect('/admin/login');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/novels');
}

const db = Astro.locals.runtime.env.DB;
const project = await getNovelProjectById(db, id);

if (!project) {
  return Astro.redirect('/admin/novels');
}

const chapters = await getNovelChaptersByProjectId(db, id);
const sources = await getNovelReferenceSources(db, id);
const nextChapter = getNextNovelChapterPosition(chapters);
const error = Astro.url.searchParams.get('error');
const pageData = serializeInlineJson({
  projectId: project.id,
  researchApiUrl: `/api/admin/novels/${project.id}/research`,
  bibleApiUrl: `/api/admin/novels/${project.id}/bible`,
  outlineApiUrl: `/api/admin/novels/${project.id}/outline`,
  planNextApiUrl: `/api/admin/novels/${project.id}/plan-next`,
  generateApiUrl: `/api/admin/novels/${project.id}/generate`,
  sources: sources.map((source) => ({
    title: source.title,
    url: source.url,
    snippet: source.snippet,
    excerpt: source.excerpt,
  })),
});
---

<AdminLayout title={`小说工作台：${project.title}`} description="维护参考作品、世界观和连续记忆，然后按章节持续续写。">
  <section class="grid three" style="padding-top: 0;">
    <article class="content-card">
      <h3>当前状态</h3>
      <p id="novel-project-status" class="admin-stat-value" style="font-size: 1.3rem;">{project.status === 'planning' ? '筹备中' : project.status === 'serializing' ? '连载中' : project.status === 'paused' ? '已暂停' : '已完结'}</p>
    </article>
    <article class="content-card">
      <h3>已写章节</h3>
      <p id="novel-project-chapters-count" class="admin-stat-value">{project.chaptersCount}</p>
    </article>
    <article class="content-card">
      <h3>下一章</h3>
      <p id="novel-project-next-chapter" class="admin-stat-value" style="font-size: 1.3rem;">第 {nextChapter.chapterNumber} 章</p>
    </article>
  </section>

  <section class="grid two" style="padding-top: 1.5rem;">
    <div>
      <AdminNovelForm
        action={`/api/admin/novels/${project.id}`}
        submitLabel="保存项目更新"
        project={project}
        error={error ? '小说项目校验失败，请检查后重试。' : undefined}
      />
    </div>

    <article class="content-card">
      <h2 class="section-title">AI 续写</h2>
      <p class="section-description">这里会读取和 AI 写作页共享的 Base URL、API Key 和模型配置，也支持直接一键自动续写下一章。</p>

      <div class="admin-form">
        <label class="admin-field">
          <span>Base URL</span>
          <input id="novel-ai-base-url" class="search-input admin-input-rect" type="text" placeholder="例如 https://api.openai.com/v1" />
        </label>

        <label class="admin-field">
          <span>API Key</span>
          <input id="novel-ai-api-key" class="search-input admin-input-rect" type="password" placeholder="输入可用的 API Key" />
        </label>

        <div class="hero-actions">
          <button id="novel-load-models" class="button" type="button">获取模型列表</button>
          <button id="novel-research-button" class="button" type="button">检索参考作品</button>
          <button id="novel-bible-button" class="button" type="button">生成人物与设定卡</button>
          <button id="novel-outline-button" class="button" type="button">生成分卷骨架</button>
          <button id="novel-plan-next-button" class="button" type="button">生成下一章任务卡</button>
        </div>

        <label class="admin-field">
          <span>模型</span>
          <select id="novel-ai-model" class="search-input admin-input-rect">
            <option value="">请先加载模型</option>
          </select>
        </label>
      </div>

      <form id="novel-generate-form" class="admin-form" style="margin-top: 1.25rem;">
        <div class="grid two">
          <label class="admin-field">
            <span>卷号</span>
            <input class="search-input admin-input-rect" type="number" name="volumeNumber" min="1" value={nextChapter.volumeNumber} />
          </label>

          <label class="admin-field">
            <span>章号</span>
            <input class="search-input admin-input-rect" type="number" name="chapterNumber" min="1" value={nextChapter.chapterNumber} />
          </label>
        </div>

        <label class="admin-field">
          <span>建议章名</span>
          <input class="search-input admin-input-rect" type="text" name="chapterTitleHint" placeholder="例如 黑市交易" />
        </label>

        <label class="admin-field">
          <span>本章任务说明</span>
          <textarea class="search-input admin-input-rect admin-textarea admin-textarea-sm" name="chapterBrief" placeholder="写清楚这章要推进什么、谁要出场、冲突和钩子是什么。" required></textarea>
        </label>

        <input type="hidden" name="chapterRole" value="" />
        <input type="hidden" name="titleDirection" value="" />
        <input type="hidden" name="endingStrategy" value="" />
        <input type="hidden" name="endingNote" value="" />

        <div id="novel-plan-output" class="ai-preset-summary" hidden></div>

        <div class="grid two">
          <label class="admin-field">
            <span>篇幅</span>
            <select class="search-input admin-input-rect" name="lengthPreset">
              <option value="tight">紧凑章节</option>
              <option value="standard" selected>标准章节</option>
              <option value="expanded">展开章节</option>
            </select>
          </label>

          <label class="admin-field">
            <span>保存方式</span>
            <select class="search-input admin-input-rect" name="status">
              <option value="draft" selected>保存为草稿</option>
              <option value="published">直接发布</option>
            </select>
          </label>
        </div>

        <label class="admin-field">
          <span>连续自动写作章数</span>
          <select class="search-input admin-input-rect" name="batchCount">
            <option value="2">连续写 2 章</option>
            <option value="3" selected>连续写 3 章</option>
            <option value="5">连续写 5 章</option>
          </select>
        </label>

        <div class="hero-actions">
          <button id="generate-novel-chapter-auto" class="button" type="button">一键自动续写下一章</button>
          <button id="generate-novel-chapter-batch" class="button" type="button">自动连续写多章</button>
          <button id="generate-novel-chapter" class="button button-primary" type="submit">按当前任务写这一章</button>
        </div>
      </form>
    </article>
  </section>

  <section class="section" style="padding-top: 1.5rem; padding-bottom: 0;">
    <div class="content-card">
      <h2 class="section-title">生成状态</h2>
      <p class="section-description">会先整理参考资料，再流式输出章节正文，最后自动把章节写入博客文章并更新连续记忆。</p>
      <div class="novel-progress-shell">
        <div class="novel-progress-header">
          <div class="hero-actions" style="margin: 0;">
            <span id="novel-run-badge" class="admin-run-badge is-idle">待命</span>
            <strong id="novel-run-phase" class="novel-progress-phase">等待开始</strong>
          </div>
          <div id="novel-status-body" class="admin-status-text">等待开始续写...</div>
        </div>

        <div class="novel-progress-meta">
          <article class="novel-progress-metric">
            <span class="novel-progress-metric-label">运行模式</span>
            <strong id="novel-run-mode">未开始</strong>
          </article>
          <article class="novel-progress-metric">
            <span class="novel-progress-metric-label">当前进度</span>
            <strong id="novel-run-progress">0 / 0</strong>
          </article>
          <article class="novel-progress-metric">
            <span class="novel-progress-metric-label">当前目标</span>
            <strong id="novel-run-target">未开始</strong>
          </article>
        </div>

        <div class="novel-progress-steps">
          <div class="novel-progress-step is-pending" data-novel-step="research">资料准备</div>
          <div class="novel-progress-step is-pending" data-novel-step="plan">任务规划</div>
          <div class="novel-progress-step is-pending" data-novel-step="write">正文写作</div>
          <div class="novel-progress-step is-pending" data-novel-step="save">保存与记忆</div>
          <div class="novel-progress-step is-pending" data-novel-step="done">完成</div>
        </div>

        <div class="novel-progress-log-shell">
          <div class="novel-progress-log-title">运行日志</div>
          <div id="novel-progress-log" class="novel-progress-log">
            <div class="novel-progress-log-empty">还没有运行记录。</div>
          </div>
        </div>
      </div>
      <div id="novel-result-actions" class="hero-actions" style="margin-top: 1rem;"></div>
    </div>
  </section>

  <section class="grid two" style="padding-top: 1.5rem;">
    <div class="content-card">
      <h2 class="section-title">参考资料</h2>
      <p class="section-description">优先保存公开摘要和世界观笔记，不直接喂整本原文。</p>
      <div id="novel-research-output" class="ai-research-output">
        <div class="ai-research-placeholder">还没有检索结果。</div>
      </div>
    </div>

    <div class="content-card">
      <h2 class="section-title">章节列表</h2>
      <p class="section-description">每一章都会同步成博客文章，并回写连续记忆。</p>
      {chapters.length > 0 ? (
        <div class="admin-insight-list">
          {chapters.map((chapter) => (
            <article class="admin-insight-row">
              <div>
                <p class="admin-insight-title">第 {chapter.volumeNumber} 卷 第 {chapter.chapterNumber} 章《{chapter.title}》</p>
                <p class="admin-insight-meta">{chapter.summary || chapter.description}</p>
              </div>
              <div class="hero-actions" style="margin-top: 0;">
                {chapter.postId ? <a class="button" href={`/admin/novels/${project.id}/chapters/${chapter.id}`}>编辑章节</a> : null}
                {chapter.status === 'published' ? <a class="button" href={getNovelChapterUrl(project.slug, chapter.volumeNumber, chapter.chapterNumber)} target="_blank" rel="noreferrer">查看前台</a> : null}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">还没有写任何章节，先在右侧填好本章任务说明再开始。</div>
      )}
    </div>
  </section>

  <section class="section" style="padding-top: 1.5rem;">
    <div class="content-card">
      <h2 class="section-title">流式预览</h2>
      <p class="section-description">这里会实时显示 AI 正在写的章节草稿。</p>
      <pre id="novel-stream-output" class="ai-stream-output">等待开始续写...</pre>
    </div>
  </section>

  <script type="application/json" id="novel-page-data" set:html={pageData}></script>
  <script is:inline>
    const STORAGE_KEYS = {
      baseUrl: 'ajc.ai.baseUrl',
      apiKey: 'ajc.ai.apiKey',
      model: 'ajc.ai.model',
    };
    const EMPTY_STREAM_TEXT = '等待开始续写...';
    const pageDataNode = document.querySelector('#novel-page-data');
    const PAGE_DATA = JSON.parse(pageDataNode?.textContent || '{}');
    const projectForm = document.querySelector('#novel-project-form');
    const generateForm = document.querySelector('#novel-generate-form');
    const baseUrlInput = document.querySelector('#novel-ai-base-url');
    const apiKeyInput = document.querySelector('#novel-ai-api-key');
    const modelSelect = document.querySelector('#novel-ai-model');
    const loadModelsButton = document.querySelector('#novel-load-models');
    const researchButton = document.querySelector('#novel-research-button');
    const bibleButton = document.querySelector('#novel-bible-button');
    const outlineButton = document.querySelector('#novel-outline-button');
    const planNextButton = document.querySelector('#novel-plan-next-button');
    const autoGenerateButton = document.querySelector('#generate-novel-chapter-auto');
    const batchGenerateButton = document.querySelector('#generate-novel-chapter-batch');
    const generateButton = document.querySelector('#generate-novel-chapter');
    const statusBody = document.querySelector('#novel-status-body');
    const streamOutput = document.querySelector('#novel-stream-output');
    const resultActions = document.querySelector('#novel-result-actions');
    const researchOutput = document.querySelector('#novel-research-output');
    const planOutput = document.querySelector('#novel-plan-output');
    const projectStatusValue = document.querySelector('#novel-project-status');
    const projectChaptersCountValue = document.querySelector('#novel-project-chapters-count');
    const projectNextChapterValue = document.querySelector('#novel-project-next-chapter');
    const runBadge = document.querySelector('#novel-run-badge');
    const runPhaseValue = document.querySelector('#novel-run-phase');
    const runModeValue = document.querySelector('#novel-run-mode');
    const runProgressValue = document.querySelector('#novel-run-progress');
    const runTargetValue = document.querySelector('#novel-run-target');
    const runLog = document.querySelector('#novel-progress-log');
    const runStepNodes = Array.from(document.querySelectorAll('[data-novel-step]'));

    const PROJECT_STATUS_LABELS = {
      planning: '筹备中',
      serializing: '连载中',
      paused: '已暂停',
      completed: '已完结',
    };
    const RUN_STEP_ORDER = ['research', 'plan', 'write', 'save', 'done'];
    const RUN_STEP_LABELS = {
      research: '资料准备',
      plan: '任务规划',
      write: '正文写作',
      save: '保存与记忆',
      done: '完成',
    };
    const BUTTON_LABELS = {
      manual: {
        idle: '按当前任务写这一章',
        busy: '写作中...',
      },
      auto: {
        idle: '一键自动续写下一章',
        busy: '自动续写中...',
      },
      batch: {
        idle: '自动连续写多章',
        busy: '连续写作中...',
      },
    };
    const runState = {
      mode: '未开始',
      progress: '0 / 0',
      target: '未开始',
      badge: 'idle',
      phase: '等待开始',
      lastLogMessage: '',
    };

    const formatTime = () => new Intl.DateTimeFormat('zh-CN', {
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: false,
    }).format(new Date());

    const setRunBadge = (badge = 'idle') => {
      runState.badge = badge;

      if (!runBadge) {
        return;
      }

      runBadge.className = `admin-run-badge is-${badge}`;
      runBadge.textContent = badge === 'running'
        ? '进行中'
        : badge === 'success'
          ? '已完成'
          : badge === 'error'
            ? '失败'
            : '待命';
    };

    const renderRunSteps = (activeStep = 'research', state = 'idle') => {
      const activeIndex = RUN_STEP_ORDER.indexOf(activeStep);

      runStepNodes.forEach((node) => {
        const step = node.dataset.novelStep;
        const stepIndex = RUN_STEP_ORDER.indexOf(step);

        node.classList.remove('is-pending', 'is-active', 'is-done', 'is-error');

        if (state === 'idle') {
          node.classList.add('is-pending');
          return;
        }

        if (state === 'success') {
          node.classList.add(stepIndex <= activeIndex ? 'is-done' : 'is-pending');
          return;
        }

        if (state === 'error') {
          if (stepIndex < activeIndex) {
            node.classList.add('is-done');
          } else if (stepIndex === activeIndex) {
            node.classList.add('is-error');
          } else {
            node.classList.add('is-pending');
          }

          return;
        }

        if (stepIndex < activeIndex) {
          node.classList.add('is-done');
        } else if (stepIndex === activeIndex) {
          node.classList.add('is-active');
        } else {
          node.classList.add('is-pending');
        }
      });
    };

    const appendRunLog = (message, tone = 'info') => {
      const normalized = String(message ?? '').trim();

      if (!runLog || !normalized || normalized === runState.lastLogMessage) {
        return;
      }

      runState.lastLogMessage = normalized;

      const emptyState = runLog.querySelector('.novel-progress-log-empty');
      emptyState?.remove();

      const entry = document.createElement('article');
      entry.className = `novel-progress-log-entry is-${tone}`;

      const time = document.createElement('span');
      time.className = 'novel-progress-log-time';
      time.textContent = formatTime();
      entry.append(time);

      const text = document.createElement('span');
      text.className = 'novel-progress-log-text';
      text.textContent = normalized;
      entry.append(text);

      runLog.prepend(entry);

      while (runLog.children.length > 10) {
        runLog.removeChild(runLog.lastElementChild);
      }
    };

    const setRunMeta = ({ mode, progress, target, phase, badge, step, logMessage, tone } = {}) => {
      if (mode) {
        runState.mode = mode;
      }

      if (progress) {
        runState.progress = progress;
      }

      if (target) {
        runState.target = target;
      }

      if (phase) {
        runState.phase = phase;
      }

      if (runModeValue) {
        runModeValue.textContent = runState.mode;
      }

      if (runProgressValue) {
        runProgressValue.textContent = runState.progress;
      }

      if (runTargetValue) {
        runTargetValue.textContent = runState.target;
      }

      if (runPhaseValue) {
        runPhaseValue.textContent = runState.phase;
      }

      if (badge) {
        setRunBadge(badge);
      }

      if (step) {
        renderRunSteps(step, badge === 'success' ? 'success' : badge === 'error' ? 'error' : 'running');
      }

      if (logMessage) {
        appendRunLog(logMessage, tone || (badge === 'error' ? 'error' : badge === 'success' ? 'success' : 'info'));
      }
    };

    const resetRunFeedback = ({ mode, progress, target, detail }) => {
      runState.lastLogMessage = '';

      if (runLog) {
        runLog.innerHTML = '<div class="novel-progress-log-empty">还没有运行记录。</div>';
      }

      setRunMeta({
        mode,
        progress,
        target,
        phase: '准备启动',
        badge: 'running',
      });
      renderRunSteps('research', 'running');
      setStatus(detail || '已收到写作请求，准备启动...', false);
      appendRunLog(detail || '已收到写作请求，准备启动...');
    };

    const inferStepFromStatus = (message) => {
      const normalized = String(message ?? '');

      if (/参考作品|参考资料|公开资料|检索/.test(normalized)) {
        return 'research';
      }

      if (/任务卡|规划/.test(normalized)) {
        return 'plan';
      }

      if (/流式写作|续写|写这一章|正在写/.test(normalized)) {
        return 'write';
      }

      if (/写入博客|整理章节记忆|保存|回写|落库/.test(normalized)) {
        return 'save';
      }

      return 'write';
    };

    const getTargetLabelFromValues = (volumeNumber, chapterNumber) => `第 ${volumeNumber} 卷 第 ${chapterNumber} 章`;

    let latestStatusMessage = statusBody?.textContent?.trim() || '等待开始生成...';

    const setStatus = (message, isError = false) => {
      latestStatusMessage = String(message ?? '').trim() || latestStatusMessage;
      statusBody.textContent = message;
      statusBody.className = isError ? 'admin-status-text is-error' : 'admin-status-text';
    };

    const setHeartbeatStatus = (message) => {
      if (!statusBody || statusBody.classList.contains('is-error')) {
        return;
      }

      statusBody.textContent = String(message ?? '').trim() || `${latestStatusMessage}（连接正常，仍在处理中...）`;
      statusBody.className = 'admin-status-text';
    };

    const setGenerationButtonsDisabled = (disabled, activeButtonKey = null) => {
      const buttonMappings = [
        ['manual', generateButton],
        ['auto', autoGenerateButton],
        ['batch', batchGenerateButton],
      ];

      buttonMappings.forEach(([key, button]) => {
        if (!button) {
          return;
        }

        button.disabled = disabled;
        button.textContent = disabled && activeButtonKey === key
          ? BUTTON_LABELS[key].busy
          : BUTTON_LABELS[key].idle;
      });
    };

    const loadStoredConfig = () => {
      try {
        return {
          baseUrl: localStorage.getItem(STORAGE_KEYS.baseUrl) || '',
          apiKey: localStorage.getItem(STORAGE_KEYS.apiKey) || '',
          model: localStorage.getItem(STORAGE_KEYS.model) || '',
        };
      } catch {
        return {
          baseUrl: '',
          apiKey: '',
          model: '',
        };
      }
    };

    const saveStoredConfig = () => {
      try {
        localStorage.setItem(STORAGE_KEYS.baseUrl, baseUrlInput?.value?.trim() || '');
        localStorage.setItem(STORAGE_KEYS.apiKey, apiKeyInput?.value?.trim() || '');
        localStorage.setItem(STORAGE_KEYS.model, modelSelect?.value?.trim() || '');
      } catch {
        // Ignore storage errors.
      }
    };

    const restoreStoredConfig = () => {
      const stored = loadStoredConfig();

      if (stored.baseUrl) {
        baseUrlInput.value = stored.baseUrl;
      }

      if (stored.apiKey) {
        apiKeyInput.value = stored.apiKey;
      }

      if (stored.model) {
        modelSelect.innerHTML = `<option value="${stored.model}">${stored.model}</option>`;
        modelSelect.value = stored.model;
      }
    };

    const fillModels = (models) => {
      modelSelect.innerHTML = '';

      if (!Array.isArray(models) || !models.length) {
        modelSelect.innerHTML = '<option value="">没有可用模型</option>';
        return;
      }

      const storedModel = loadStoredConfig().model;

      models.forEach((model, index) => {
        const option = document.createElement('option');
        option.value = model.id;
        option.textContent = model.id;
        option.selected = storedModel ? model.id === storedModel : index === 0;
        modelSelect.append(option);
      });
    };

    const gatherProjectSnapshot = () => ({
      slug: String(projectForm?.elements?.namedItem('slug')?.value ?? ''),
      title: String(projectForm?.elements?.namedItem('title')?.value ?? ''),
      premise: String(projectForm?.elements?.namedItem('premise')?.value ?? ''),
      genre: String(projectForm?.elements?.namedItem('genre')?.value ?? ''),
      writingGoals: String(projectForm?.elements?.namedItem('writingGoals')?.value ?? ''),
      referenceTitle: String(projectForm?.elements?.namedItem('referenceTitle')?.value ?? ''),
      referenceSummary: String(projectForm?.elements?.namedItem('referenceSummary')?.value ?? ''),
      referenceNotes: String(projectForm?.elements?.namedItem('referenceNotes')?.value ?? ''),
      worldBible: String(projectForm?.elements?.namedItem('worldBible')?.value ?? ''),
      characterBible: String(projectForm?.elements?.namedItem('characterBible')?.value ?? ''),
      outline: String(projectForm?.elements?.namedItem('outline')?.value ?? ''),
      styleGuide: String(projectForm?.elements?.namedItem('styleGuide')?.value ?? ''),
      continuityNotes: String(projectForm?.elements?.namedItem('continuityNotes')?.value ?? ''),
      status: String(projectForm?.elements?.namedItem('status')?.value ?? 'planning'),
    });

    const renderResearchOutput = ({ query, sources, message }) => {
      researchOutput.innerHTML = '';

      const summary = document.createElement('div');
      summary.className = 'ai-research-summary';
      summary.textContent = message || '还没有检索结果。';
      researchOutput.append(summary);

      if (query) {
        const queryNode = document.createElement('div');
        queryNode.className = 'ai-research-query';
        queryNode.textContent = `检索词：${query}`;
        researchOutput.append(queryNode);
      }

      if (!Array.isArray(sources) || !sources.length) {
        return;
      }

      sources.forEach((source) => {
        const item = document.createElement('article');
        item.className = 'ai-research-item';

        const title = document.createElement('h3');
        title.className = 'ai-research-item-title';
        title.textContent = source.title || '未命名来源';
        item.append(title);

        if (source.url) {
          const link = document.createElement('a');
          link.className = 'ai-research-item-link';
          link.href = source.url;
          link.target = '_blank';
          link.rel = 'noreferrer';
          link.textContent = source.url;
          item.append(link);
        }

        const snippet = document.createElement('p');
        snippet.className = 'ai-research-item-snippet';
        snippet.textContent = source.excerpt || source.snippet || '';
        item.append(snippet);
        researchOutput.append(item);
      });
    };

    const renderPlanOutput = (plan) => {
      if (!planOutput) {
        return;
      }

      planOutput.hidden = false;
      planOutput.innerHTML = '';

      const title = document.createElement('div');
      title.className = 'ai-preset-title';
      title.textContent = plan.chapterTitleHint || '下一章任务卡';
      planOutput.append(title);

      if (plan.chapterBrief) {
        const brief = document.createElement('p');
        brief.className = 'ai-preset-copy';
        brief.textContent = plan.chapterBrief;
        planOutput.append(brief);
      }

      const strategyParts = [
        plan.chapterRole ? `本章功能：${plan.chapterRole}` : '',
        plan.titleDirection ? `标题方向：${plan.titleDirection}` : '',
        plan.endingStrategy ? `结尾策略：${plan.endingStrategy}` : '',
      ].filter(Boolean);

      if (strategyParts.length) {
        const strategy = document.createElement('p');
        strategy.className = 'ai-preset-copy';
        strategy.textContent = strategyParts.join(' · ');
        planOutput.append(strategy);
      }

      if (plan.progressionChecklist) {
        const checklist = document.createElement('pre');
        checklist.className = 'ai-stream-output';
        checklist.style.minHeight = 'unset';
        checklist.style.maxHeight = '260px';
        checklist.textContent = plan.progressionChecklist;
        planOutput.append(checklist);
      }

      if (plan.endingNote) {
        const hook = document.createElement('p');
        hook.className = 'ai-preset-copy';
        hook.textContent = `结尾处理：${plan.endingNote}`;
        planOutput.append(hook);
      }
    };

    const applyPlanToForm = (plan) => {
      const titleField = generateForm?.elements?.namedItem('chapterTitleHint');
      const briefField = generateForm?.elements?.namedItem('chapterBrief');
      const chapterRoleField = generateForm?.elements?.namedItem('chapterRole');
      const titleDirectionField = generateForm?.elements?.namedItem('titleDirection');
      const endingStrategyField = generateForm?.elements?.namedItem('endingStrategy');
      const endingNoteField = generateForm?.elements?.namedItem('endingNote');

      if (titleField && 'value' in titleField) {
        titleField.value = plan.chapterTitleHint || '';
      }

      if (chapterRoleField && 'value' in chapterRoleField) {
        chapterRoleField.value = plan.chapterRole || '';
      }

      if (titleDirectionField && 'value' in titleDirectionField) {
        titleDirectionField.value = plan.titleDirection || '';
      }

      if (endingStrategyField && 'value' in endingStrategyField) {
        endingStrategyField.value = plan.endingStrategy || '';
      }

      if (endingNoteField && 'value' in endingNoteField) {
        endingNoteField.value = plan.endingNote || '';
      }

      if (briefField && 'value' in briefField) {
        const combinedBrief = [
          plan.chapterBrief || '',
          plan.progressionChecklist ? `\n\n推进清单：\n${plan.progressionChecklist}` : '',
          plan.chapterRole ? `\n\n本章功能：${plan.chapterRole}` : '',
          plan.titleDirection ? `\n\n标题方向：${plan.titleDirection}` : '',
          plan.endingStrategy ? `\n\n结尾策略：${plan.endingStrategy}` : '',
          plan.endingNote ? `\n\n结尾处理：${plan.endingNote}` : '',
        ].join('').trim();
        briefField.value = combinedBrief;
      }

      renderPlanOutput(plan);
    };

    const clearPlanFromForm = () => {
      const titleField = generateForm?.elements?.namedItem('chapterTitleHint');
      const briefField = generateForm?.elements?.namedItem('chapterBrief');
      const chapterRoleField = generateForm?.elements?.namedItem('chapterRole');
      const titleDirectionField = generateForm?.elements?.namedItem('titleDirection');
      const endingStrategyField = generateForm?.elements?.namedItem('endingStrategy');
      const endingNoteField = generateForm?.elements?.namedItem('endingNote');

      if (titleField && 'value' in titleField) {
        titleField.value = '';
      }

      if (briefField && 'value' in briefField) {
        briefField.value = '';
      }

      [chapterRoleField, titleDirectionField, endingStrategyField, endingNoteField].forEach((field) => {
        if (field && 'value' in field) {
          field.value = '';
        }
      });

      if (planOutput) {
        planOutput.hidden = true;
        planOutput.innerHTML = '';
      }
    };

    const applyNextChapterToForm = (nextChapter) => {
      if (!nextChapter) {
        return;
      }

      const volumeField = generateForm?.elements?.namedItem('volumeNumber');
      const chapterField = generateForm?.elements?.namedItem('chapterNumber');

      if (volumeField && 'value' in volumeField) {
        volumeField.value = String(nextChapter.volumeNumber ?? 1);
      }

      if (chapterField && 'value' in chapterField) {
        chapterField.value = String(nextChapter.chapterNumber ?? 1);
      }

      if (projectNextChapterValue) {
        projectNextChapterValue.textContent = `第 ${nextChapter.chapterNumber ?? 1} 章`;
      }

      clearPlanFromForm();
    };

    const updateProjectStats = (project) => {
      if (!project) {
        return;
      }

      if (project.status && projectStatusValue) {
        projectStatusValue.textContent = PROJECT_STATUS_LABELS[project.status] || project.status;
      }

      if (typeof project.chaptersCount === 'number' && projectChaptersCountValue) {
        projectChaptersCountValue.textContent = String(project.chaptersCount);
      }

      if (project.nextChapter) {
        applyNextChapterToForm(project.nextChapter);
      }
    };

    const setResultActions = (post) => {
      resultActions.innerHTML = '';

      if (!post) {
        return;
      }

      const editLink = document.createElement('a');
      editLink.className = 'button button-primary';
      editLink.href = post.adminUrl;
      editLink.textContent = '打开文章编辑';
      resultActions.append(editLink);

      if (post.publicUrl) {
        const publicLink = document.createElement('a');
        publicLink.className = 'button';
        publicLink.href = post.publicUrl;
        publicLink.target = '_blank';
        publicLink.rel = 'noreferrer';
        publicLink.textContent = '查看前台';
        resultActions.append(publicLink);
      }

      const refreshButton = document.createElement('button');
      refreshButton.className = 'button';
      refreshButton.type = 'button';
      refreshButton.textContent = '刷新章节列表';
      refreshButton.addEventListener('click', () => window.location.reload());
      resultActions.append(refreshButton);
    };

    const readEventStream = async (response, handlers) => {
      if (!response.body) {
        throw new Error('服务端没有返回可读取的流式内容。');
      }

      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';
      let hasTerminalEvent = false;

      const processEventText = (eventText) => {
        if (!eventText.trim() || eventText.trim().startsWith(':')) {
          return;
        }

        const lines = eventText.split(/\r?\n/);
        const eventLine = lines.find((line) => line.startsWith('event:'));
        const dataLines = lines
          .filter((line) => line.startsWith('data:'))
          .map((line) => line.slice(5).trimStart())
          .filter(Boolean);

        if (!eventLine || !dataLines.length) {
          return;
        }

        const eventName = eventLine.slice(6).trim();
        const payload = JSON.parse(dataLines.join('\n'));

        if (eventName === 'done' || eventName === 'error') {
          hasTerminalEvent = true;
        }

        const handler = handlers[eventName];
        if (handler) {
          handler(payload);
        }
      };

      try {
        while (true) {
          const { done, value } = await reader.read();

          if (done) {
            break;
          }

          buffer += decoder.decode(value, { stream: true });
          const events = buffer.split(/\r?\n\r?\n/);
          buffer = events.pop() ?? '';

          for (const eventText of events) {
            processEventText(eventText);
          }
        }

        buffer += decoder.decode();

        if (buffer.trim()) {
          processEventText(buffer);
        }
      } finally {
        try {
          reader.releaseLock();
        } catch {
          // Ignore stream cleanup failures.
        }
      }

      if (!hasTerminalEvent) {
        throw new Error('流式连接意外中断，服务端没有返回完成信号，请重试。');
      }
    };

    restoreStoredConfig();
    setRunMeta({
      mode: runState.mode,
      progress: runState.progress,
      target: runState.target,
      phase: runState.phase,
      badge: runState.badge,
    });
    renderRunSteps('research', 'idle');
    renderResearchOutput({
      query: '',
      sources: PAGE_DATA.sources || [],
      message: Array.isArray(PAGE_DATA.sources) && PAGE_DATA.sources.length
        ? `已载入 ${PAGE_DATA.sources.length} 条参考资料。`
        : '还没有检索结果。',
    });

    [baseUrlInput, apiKeyInput, modelSelect].forEach((field) => {
      field?.addEventListener('change', saveStoredConfig);
    });

    loadModelsButton?.addEventListener('click', async () => {
      const baseUrl = baseUrlInput?.value?.trim();
      const apiKey = apiKeyInput?.value?.trim();

      if (!baseUrl || !apiKey) {
        setStatus('请先填写 Base URL 和 API Key。', true);
        return;
      }

      loadModelsButton.disabled = true;
      setStatus('正在获取模型列表...');

      try {
        const response = await fetch('/api/admin/ai/models', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ baseUrl, apiKey }),
        });
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || '获取模型列表失败。');
        }

        fillModels(data.models || []);
        saveStoredConfig();
        setStatus(`已获取 ${data.models?.length ?? 0} 个模型。`);
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '获取模型列表失败。', true);
      } finally {
        loadModelsButton.disabled = false;
      }
    });

    researchButton?.addEventListener('click', async () => {
      researchButton.disabled = true;
      setStatus('正在检索参考作品资料...');

      try {
        const response = await fetch(PAGE_DATA.researchApiUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            baseUrl: baseUrlInput?.value?.trim() || '',
            apiKey: apiKeyInput?.value?.trim() || '',
            model: modelSelect?.value?.trim() || '',
            project: gatherProjectSnapshot(),
          }),
        });
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || '检索参考资料失败。');
        }

        const referenceSummaryField = projectForm?.elements?.namedItem('referenceSummary');
        const referenceNotesField = projectForm?.elements?.namedItem('referenceNotes');

        if (referenceSummaryField && 'value' in referenceSummaryField) {
          referenceSummaryField.value = data.referenceSummary || '';
        }

        if (referenceNotesField && 'value' in referenceNotesField) {
          referenceNotesField.value = data.referenceNotes || '';
        }

        renderResearchOutput(data);
        setStatus(data.message || '参考资料整理完成。');
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '检索参考资料失败。', true);
      } finally {
        researchButton.disabled = false;
      }
    });

    bibleButton?.addEventListener('click', async () => {
      bibleButton.disabled = true;
      setStatus('正在生成人物卡、世界观和文风约束...');

      try {
        const response = await fetch(PAGE_DATA.bibleApiUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            baseUrl: baseUrlInput?.value?.trim() || '',
            apiKey: apiKeyInput?.value?.trim() || '',
            model: modelSelect?.value?.trim() || '',
            project: gatherProjectSnapshot(),
          }),
        });
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || '生成人物与设定卡失败。');
        }

        [
          ['writingGoals', data.writingGoals],
          ['worldBible', data.worldBible],
          ['characterBible', data.characterBible],
          ['styleGuide', data.styleGuide],
        ].forEach(([name, value]) => {
          const field = projectForm?.elements?.namedItem(name);

          if (field && 'value' in field) {
            field.value = value || '';
          }
        });

        setStatus(data.message || '人物与设定卡生成完成。');
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '生成人物与设定卡失败。', true);
      } finally {
        bibleButton.disabled = false;
      }
    });

    outlineButton?.addEventListener('click', async () => {
      outlineButton.disabled = true;
      setStatus('正在生成分卷与分章节骨架...');

      try {
        const response = await fetch(PAGE_DATA.outlineApiUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            baseUrl: baseUrlInput?.value?.trim() || '',
            apiKey: apiKeyInput?.value?.trim() || '',
            model: modelSelect?.value?.trim() || '',
            targetVolumes: 3,
            chaptersPerVolume: 8,
            project: gatherProjectSnapshot(),
          }),
        });
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || '生成分卷骨架失败。');
        }

        const outlineField = projectForm?.elements?.namedItem('outline');

        if (outlineField && 'value' in outlineField) {
          outlineField.value = data.outline || '';
        }

        setStatus(data.message || '分卷骨架生成完成。');
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '生成分卷骨架失败。', true);
      } finally {
        outlineButton.disabled = false;
      }
    });

    planNextButton?.addEventListener('click', async () => {
      planNextButton.disabled = true;
      setStatus('正在生成下一章任务卡...');

      try {
        const volumeNumber = Number(generateForm?.elements?.namedItem('volumeNumber')?.value ?? 1);
        const chapterNumber = Number(generateForm?.elements?.namedItem('chapterNumber')?.value ?? 1);
        const response = await fetch(PAGE_DATA.planNextApiUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            baseUrl: baseUrlInput?.value?.trim() || '',
            apiKey: apiKeyInput?.value?.trim() || '',
            model: modelSelect?.value?.trim() || '',
            volumeNumber,
            chapterNumber,
            project: gatherProjectSnapshot(),
          }),
        });
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || '生成下一章任务卡失败。');
        }

        applyPlanToForm(data);
        setStatus(data.message || '下一章任务卡生成完成。');
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '生成下一章任务卡失败。', true);
      } finally {
        planNextButton.disabled = false;
      }
    });

    const runGenerate = async ({ autoPlan = false, manageButtons = true, resetOutput = true } = {}) => {
      const baseUrl = baseUrlInput?.value?.trim();
      const apiKey = apiKeyInput?.value?.trim();
      const model = modelSelect?.value?.trim();

      if (!baseUrl || !apiKey || !model) {
        setStatus('请先填写模型配置并加载可用模型。', true);
        return;
      }

      const formData = new FormData(generateForm);
      saveStoredConfig();

      if (manageButtons) {
        setGenerationButtonsDisabled(true);
      }

      if (resetOutput) {
        streamOutput.textContent = EMPTY_STREAM_TEXT;
        resultActions.innerHTML = '';
      }

      setStatus(autoPlan ? '正在自动规划并续写下一章...' : '正在启动小说续写...');
      let donePayload = null;
      let streamFailed = false;
      let streamErrorMessage = '';

      try {
        const response = await fetch(PAGE_DATA.generateApiUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'text/event-stream',
          },
          body: JSON.stringify({
            baseUrl,
            apiKey,
            model,
            project: gatherProjectSnapshot(),
            volumeNumber: Number(formData.get('volumeNumber') ?? 1),
            chapterNumber: Number(formData.get('chapterNumber') ?? 1),
            chapterTitleHint: String(formData.get('chapterTitleHint') ?? ''),
            chapterBrief: String(formData.get('chapterBrief') ?? ''),
            chapterRole: String(formData.get('chapterRole') ?? ''),
            titleDirection: String(formData.get('titleDirection') ?? ''),
            endingStrategy: String(formData.get('endingStrategy') ?? ''),
            endingNote: String(formData.get('endingNote') ?? ''),
            lengthPreset: String(formData.get('lengthPreset') ?? 'standard'),
            status: String(formData.get('status') ?? 'draft'),
            autoPlan,
          }),
        });

        if (!response.ok) {
          const data = await response.json();
          throw new Error(data.message || '章节生成失败。');
        }

        await readEventStream(response, {
          status: (data) => {
            setStatus(data.message || 'AI 正在续写...');
          },
          heartbeat: (data) => {
            setHeartbeatStatus(data.message);
          },
          research: (data) => {
            const referenceSummaryField = projectForm?.elements?.namedItem('referenceSummary');
            const referenceNotesField = projectForm?.elements?.namedItem('referenceNotes');

            if (referenceSummaryField && 'value' in referenceSummaryField && data.referenceSummary) {
              referenceSummaryField.value = data.referenceSummary;
            }

            if (referenceNotesField && 'value' in referenceNotesField && data.referenceNotes) {
              referenceNotesField.value = data.referenceNotes;
            }

            renderResearchOutput(data);
          },
          plan: (data) => {
            applyPlanToForm(data);
            setStatus(data.message || '下一章任务卡已自动生成。');
          },
          content: (data) => {
            const current = streamOutput.textContent === EMPTY_STREAM_TEXT ? '' : streamOutput.textContent;
            streamOutput.textContent = `${current}${data.chunk || ''}`;
            streamOutput.scrollTop = streamOutput.scrollHeight;
          },
          done: (data) => {
            donePayload = data;
            if (data.rawText) {
              streamOutput.textContent = data.rawText;
            }

            const continuityField = projectForm?.elements?.namedItem('continuityNotes');

            if (continuityField && 'value' in continuityField && data.project?.continuityNotes) {
              continuityField.value = data.project.continuityNotes;
            }

            updateProjectStats(data.project || null);
            setStatus(data.message || '章节生成完成。');
            setResultActions(data.post || null);
          },
          error: (data) => {
            streamFailed = true;
            streamErrorMessage = data.message || '章节生成失败，请稍后再试。';
            if (data.rawText) {
              streamOutput.textContent = data.rawText;
            }

            setStatus(streamErrorMessage, true);
          },
        });

        if (streamFailed) {
          throw new Error(streamErrorMessage);
        }

        return donePayload;
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '章节生成失败，请稍后再试。', true);
        throw error;
      } finally {
        if (manageButtons) {
          setGenerationButtonsDisabled(false);
        }
      }
    };

    autoGenerateButton?.addEventListener('click', async () => {
      await runGenerate({ autoPlan: true });
    });

    batchGenerateButton?.addEventListener('click', async () => {
      const batchCount = Math.max(1, Math.min(5, Number(generateForm?.elements?.namedItem('batchCount')?.value ?? 3) || 3));
      let completedCount = 0;

      setGenerationButtonsDisabled(true);
      resultActions.innerHTML = '';

      try {
        for (let index = 0; index < batchCount; index += 1) {
          setStatus(`正在自动连续写作第 ${index + 1} / ${batchCount} 章...`);

          await runGenerate({
            autoPlan: true,
            manageButtons: false,
            resetOutput: true,
          });

          completedCount += 1;
        }

        setStatus(`已自动连续完成 ${completedCount} 章。`);
      } catch (error) {
        setStatus(
          completedCount > 0
            ? `已完成 ${completedCount} 章，后续中断：${error instanceof Error ? error.message : '自动连续写作失败。'}`
            : (error instanceof Error ? error.message : '自动连续写作失败。'),
          true,
        );
      } finally {
        setGenerationButtonsDisabled(false);
      }
    });

    generateForm?.addEventListener('submit', async (submitEvent) => {
      submitEvent.preventDefault();
      await runGenerate({ autoPlan: false });
    });
  </script>
</AdminLayout>
