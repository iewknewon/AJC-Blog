---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { isAdminAuthenticated } from '../../lib/auth/guards';
import { AI_WRITING_PRESETS, DEFAULT_AI_WRITING_PRESET_ID } from '../../lib/ai/presets';

const authenticated = await isAdminAuthenticated(Astro.cookies, Astro.locals.runtime?.env);
const presetJson = JSON.stringify(AI_WRITING_PRESETS);

if (!authenticated) {
  return Astro.redirect('/admin/login');
}
---

<AdminLayout title="AI 写作" description="接入 OpenAI 兼容接口，一键生成较短的博客草稿，并自动补封面与正文插图。">
  <section class="grid two" style="align-items: start;">
    <article class="content-card">
      <h2 class="section-title">模型配置</h2>
      <p class="section-description">这里的 Base URL、API Key 和模型只保存在当前浏览器，方便你反复使用。</p>

      <div class="admin-form">
        <label class="admin-field">
          <span>Base URL</span>
          <input id="ai-base-url" class="search-input admin-input-rect" type="text" placeholder="例如 https://api.openai.com/v1" />
        </label>

        <label class="admin-field">
          <span>API Key</span>
          <input id="ai-api-key" class="search-input admin-input-rect" type="password" placeholder="输入可用的 API Key" />
        </label>

        <div class="hero-actions">
          <button id="load-models" class="button" type="button">获取模型列表</button>
          <button id="clear-ai-config" class="button" type="button">清空本地配置</button>
        </div>

        <label class="admin-field">
          <span>模型</span>
          <select id="ai-model" class="search-input admin-input-rect">
            <option value="">请先加载模型</option>
          </select>
        </label>
      </div>
    </article>

    <article class="content-card">
      <h2 class="section-title">写作参数</h2>
      <p class="section-description">默认会优先生成短一些、可直接发布的博客稿件，并尝试补齐封面和正文插图。</p>

      <form id="ai-writer-form" class="admin-form">
        <div class="content-card ai-preset-shell" style="padding: 1rem 1rem 1.1rem; background: var(--surface-muted); box-shadow: none;">
          <label class="admin-field">
            <span>写作模式</span>
            <select id="ai-preset" class="search-input admin-input-rect" name="presetId">
              {AI_WRITING_PRESETS.map((preset) => (
                <option value={preset.id} selected={preset.id === DEFAULT_AI_WRITING_PRESET_ID}>
                  {preset.label}
                </option>
              ))}
            </select>
          </label>

          <div class="hero-actions" style="margin-top: 0.25rem;">
            <button id="apply-ai-preset" class="button" type="button">写入提示词文本框</button>
          </div>

          <div id="ai-preset-summary" class="ai-preset-summary"></div>
        </div>

        <label class="admin-field">
          <span>文章主题</span>
          <input class="search-input admin-input-rect" type="text" name="topic" placeholder="例如：Astro + Cloudflare 博客上线指南" required />
        </label>

        <label class="admin-field">
          <span>关键词</span>
          <input class="search-input admin-input-rect" type="text" name="keywords" placeholder="例如：Astro, Cloudflare, D1, SEO" />
        </label>

        <label class="admin-field">
          <span>目标读者</span>
          <input class="search-input admin-input-rect" type="text" name="audience" placeholder="例如：独立开发者、前端工程师、新手站长" />
        </label>

        <label class="admin-field">
          <span>写作要求</span>
          <textarea class="search-input admin-input-rect admin-textarea admin-textarea-sm" name="requirements" placeholder="例如：语气自然一点，带清晰步骤，结尾给出建议，不要太学术。"></textarea>
        </label>

        <label class="admin-field">
          <span>自定义提示词</span>
          <textarea class="search-input admin-input-rect admin-textarea admin-textarea-sm" name="customPrompt" placeholder="这里可以补充风格、结构、禁用词、写作口吻等额外要求。"></textarea>
        </label>

        <label class="admin-field">
          <span>系统提示词</span>
          <textarea class="search-input admin-input-rect admin-textarea admin-textarea-sm" name="systemPrompt" placeholder="只有在你想强制指定 AI 的角色和行为规则时再填写。"></textarea>
        </label>

        <div class="content-card" style="padding: 1rem 1rem 1.1rem; background: var(--surface-muted); box-shadow: none;">
          <div class="ai-option-grid">
            <label class="admin-field">
              <span>篇幅控制</span>
              <select class="search-input admin-input-rect" name="lengthPreset">
                <option value="compact" selected>短文优先（推荐）</option>
                <option value="standard">标准长度</option>
                <option value="detailed">长文深入</option>
              </select>
            </label>

            <label class="admin-field">
              <span>正文插图数量</span>
              <select class="search-input admin-input-rect" name="illustrationCount">
                <option value="1">1 张</option>
                <option value="2" selected>2 张</option>
                <option value="3">3 张</option>
                <option value="4">4 张</option>
              </select>
            </label>
          </div>

          <label class="admin-checkbox" style="padding-top: 1rem;">
            <input type="checkbox" name="autoCoverEnabled" checked />
            <span>自动匹配封面</span>
          </label>

          <label class="admin-checkbox">
            <input type="checkbox" name="autoIllustrationsEnabled" checked />
            <span>自动插入正文配图</span>
          </label>

          <label class="admin-checkbox">
            <input type="checkbox" name="webSearchEnabled" />
            <span>写作前联网检索资料</span>
          </label>

          <label class="admin-field" style="margin-top: 0.75rem;">
            <span>联网检索词</span>
            <input class="search-input admin-input-rect" type="text" name="webSearchQuery" placeholder="留空时默认使用文章主题进行检索" />
          </label>

          <p class="muted" style="margin: 0.75rem 0 0;">自动配图会结合标题、摘要、标签和正文内容生成检索词，再从开放图片源里匹配。</p>
        </div>

        <label class="admin-field">
          <span>手动封面 URL</span>
          <input class="search-input admin-input-rect" type="url" name="cover" placeholder="留空时会在生成过程中自动匹配封面" />
        </label>

        <div class="grid two">
          <label class="admin-field">
            <span>保存方式</span>
            <select class="search-input admin-input-rect" name="status">
              <option value="draft">保存为草稿</option>
              <option value="published">直接发布</option>
            </select>
          </label>

          <label class="admin-checkbox">
            <input type="checkbox" name="featured" />
            <span>设为推荐文章</span>
          </label>
        </div>

        <div class="hero-actions">
          <button id="generate-post" class="button button-primary" type="submit">开始 AI 写作</button>
        </div>
      </form>
    </article>
  </section>

  <section class="section" style="padding-top: 1.5rem;">
    <div id="ai-status" class="content-card">
      <h2 class="section-title">生成状态</h2>
      <p class="section-description">生成过程中会先流式输出正文，再自动补封面和插图，最后直接保存到博客后台。</p>
      <div id="ai-status-body" class="muted">等待开始生成...</div>
      <div id="ai-result-actions" class="hero-actions" style="margin-top: 1rem;"></div>
    </div>
  </section>

  <section class="grid two" style="padding-top: 0;">
    <div class="content-card">
      <h2 class="section-title">联网检索结果</h2>
      <p class="section-description">如果开启了联网检索，这里会显示参与写作的参考资料。</p>
      <div id="ai-research-output" class="ai-research-output">
        <div class="ai-research-placeholder">还没有检索结果。</div>
      </div>
    </div>

    <div class="content-card">
      <h2 class="section-title">自动配图结果</h2>
      <p class="section-description">这里会显示本次自动选择的封面和正文插图，以及对应的检索词。</p>
      <div id="ai-assets-output" class="ai-assets-output">
        <div class="ai-assets-placeholder">还没有生成封面或插图。</div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="content-card">
      <h2 class="section-title">草稿源码</h2>
      <p class="section-description">这里会实时显示 AI 输出的文章源码；保存成功后，会替换成最终落库版本。</p>
      <pre id="ai-stream-output" class="ai-stream-output">等待生成内容...</pre>
    </div>
  </section>

  <script
    type="application/json"
    id="ai-writing-presets"
    data-default-preset={DEFAULT_AI_WRITING_PRESET_ID}
    set:html={presetJson}
  ></script>
  <script is:inline>
    const EMPTY_STREAM_TEXT = '等待生成内容...';
    const EMPTY_RESEARCH_TEXT = '还没有检索结果。';
    const EMPTY_ASSET_TEXT = '还没有生成封面或插图。';
    const presetDataNode = document.querySelector('#ai-writing-presets');
    const DEFAULT_PRESET_ID = presetDataNode?.dataset?.defaultPreset || 'blog-default';
    let WRITING_PRESETS = [];

    try {
      WRITING_PRESETS = JSON.parse(presetDataNode?.textContent || '[]');
    } catch (error) {
      console.error('[admin-ai] failed to parse writing presets', error);
      WRITING_PRESETS = [];
    }

    const PRESET_MAP = new Map(WRITING_PRESETS.map((preset) => [preset.id, preset]));
    const loadModelsButton = document.querySelector('#load-models');
    const generateButton = document.querySelector('#generate-post');
    const modelSelect = document.querySelector('#ai-model');
    const baseUrlInput = document.querySelector('#ai-base-url');
    const apiKeyInput = document.querySelector('#ai-api-key');
    const form = document.querySelector('#ai-writer-form');
    const statusBody = document.querySelector('#ai-status-body');
    const resultActions = document.querySelector('#ai-result-actions');
    const researchOutput = document.querySelector('#ai-research-output');
    const assetOutput = document.querySelector('#ai-assets-output');
    const streamOutput = document.querySelector('#ai-stream-output');
    const clearConfigButton = document.querySelector('#clear-ai-config');
    const presetSelect = document.querySelector('#ai-preset');
    const applyPresetButton = document.querySelector('#apply-ai-preset');
    const presetSummary = document.querySelector('#ai-preset-summary');

    const STORAGE_KEYS = {
      baseUrl: 'ajc.ai.baseUrl',
      apiKey: 'ajc.ai.apiKey',
      model: 'ajc.ai.model',
      presetId: 'ajc.ai.presetId',
      customPrompt: 'ajc.ai.customPrompt',
      systemPrompt: 'ajc.ai.systemPrompt',
      webSearchEnabled: 'ajc.ai.webSearchEnabled',
      webSearchQuery: 'ajc.ai.webSearchQuery',
      lengthPreset: 'ajc.ai.lengthPreset',
      autoCoverEnabled: 'ajc.ai.autoCoverEnabled',
      autoIllustrationsEnabled: 'ajc.ai.autoIllustrationsEnabled',
      illustrationCount: 'ajc.ai.illustrationCount',
    };

    const readNamedField = (name) => form?.elements?.namedItem(name);
    const readNamedFieldValue = (name, fallback = '') => String(readNamedField(name)?.value ?? fallback);
    const readNamedCheckboxValue = (name, fallback = false) => {
      const field = readNamedField(name);
      return field && 'checked' in field ? Boolean(field.checked) : fallback;
    };

    const buildStoredConfigSnapshot = () => ({
      baseUrl: baseUrlInput?.value?.trim() || '',
      apiKey: apiKeyInput?.value?.trim() || '',
      model: modelSelect?.value?.trim() || '',
      presetId: readNamedFieldValue('presetId', DEFAULT_PRESET_ID),
      customPrompt: readNamedFieldValue('customPrompt'),
      systemPrompt: readNamedFieldValue('systemPrompt'),
      webSearchEnabled: readNamedCheckboxValue('webSearchEnabled'),
      webSearchQuery: readNamedFieldValue('webSearchQuery'),
      lengthPreset: readNamedFieldValue('lengthPreset', 'compact'),
      autoCoverEnabled: readNamedCheckboxValue('autoCoverEnabled', true),
      autoIllustrationsEnabled: readNamedCheckboxValue('autoIllustrationsEnabled', true),
      illustrationCount: readNamedFieldValue('illustrationCount', '2'),
    });

    const loadStoredConfig = () => {
      try {
        return {
          baseUrl: localStorage.getItem(STORAGE_KEYS.baseUrl) || '',
          apiKey: localStorage.getItem(STORAGE_KEYS.apiKey) || '',
          model: localStorage.getItem(STORAGE_KEYS.model) || '',
          presetId: localStorage.getItem(STORAGE_KEYS.presetId) || DEFAULT_PRESET_ID,
          customPrompt: localStorage.getItem(STORAGE_KEYS.customPrompt) || '',
          systemPrompt: localStorage.getItem(STORAGE_KEYS.systemPrompt) || '',
          webSearchEnabled: localStorage.getItem(STORAGE_KEYS.webSearchEnabled) === '1',
          webSearchQuery: localStorage.getItem(STORAGE_KEYS.webSearchQuery) || '',
          lengthPreset: localStorage.getItem(STORAGE_KEYS.lengthPreset) || 'compact',
          autoCoverEnabled: localStorage.getItem(STORAGE_KEYS.autoCoverEnabled) !== '0',
          autoIllustrationsEnabled: localStorage.getItem(STORAGE_KEYS.autoIllustrationsEnabled) !== '0',
          illustrationCount: localStorage.getItem(STORAGE_KEYS.illustrationCount) || '2',
        };
      } catch {
        return {
          baseUrl: '',
          apiKey: '',
          model: '',
          presetId: DEFAULT_PRESET_ID,
          customPrompt: '',
          systemPrompt: '',
          webSearchEnabled: false,
          webSearchQuery: '',
          lengthPreset: 'compact',
          autoCoverEnabled: true,
          autoIllustrationsEnabled: true,
          illustrationCount: '2',
        };
      }
    };

    const saveStoredConfig = (snapshot) => {
      try {
        localStorage.setItem(STORAGE_KEYS.baseUrl, snapshot.baseUrl || '');
        localStorage.setItem(STORAGE_KEYS.apiKey, snapshot.apiKey || '');
        localStorage.setItem(STORAGE_KEYS.model, snapshot.model || '');
        localStorage.setItem(STORAGE_KEYS.presetId, snapshot.presetId || DEFAULT_PRESET_ID);
        localStorage.setItem(STORAGE_KEYS.customPrompt, snapshot.customPrompt || '');
        localStorage.setItem(STORAGE_KEYS.systemPrompt, snapshot.systemPrompt || '');
        localStorage.setItem(STORAGE_KEYS.webSearchEnabled, snapshot.webSearchEnabled ? '1' : '0');
        localStorage.setItem(STORAGE_KEYS.webSearchQuery, snapshot.webSearchQuery || '');
        localStorage.setItem(STORAGE_KEYS.lengthPreset, snapshot.lengthPreset || 'compact');
        localStorage.setItem(STORAGE_KEYS.autoCoverEnabled, snapshot.autoCoverEnabled ? '1' : '0');
        localStorage.setItem(STORAGE_KEYS.autoIllustrationsEnabled, snapshot.autoIllustrationsEnabled ? '1' : '0');
        localStorage.setItem(STORAGE_KEYS.illustrationCount, snapshot.illustrationCount || '2');
      } catch {
        // Ignore storage errors.
      }
    };

    const clearStoredConfig = () => {
      try {
        Object.values(STORAGE_KEYS).forEach((key) => localStorage.removeItem(key));
      } catch {
        // Ignore storage cleanup failures.
      }
    };

    const setStatus = (message, isError = false) => {
      statusBody.textContent = message;
      statusBody.className = isError ? 'admin-status-text is-error' : 'admin-status-text';
    };

    const setNamedFieldValue = (name, value) => {
      const field = readNamedField(name);
      if (field && 'value' in field) {
        field.value = value;
      }
    };

    const readPreset = (presetId) => PRESET_MAP.get(String(presetId || '').trim()) || PRESET_MAP.get(DEFAULT_PRESET_ID) || null;

    const updatePresetSummary = (presetId) => {
      if (!presetSummary) {
        return;
      }

      const preset = readPreset(presetId);
      presetSummary.innerHTML = '';

      if (!preset) {
        return;
      }

      const title = document.createElement('div');
      title.className = 'ai-preset-title';
      title.textContent = preset.label;
      presetSummary.append(title);

      const description = document.createElement('p');
      description.className = 'ai-preset-copy';
      description.textContent = preset.description;
      presetSummary.append(description);

      const summary = document.createElement('p');
      summary.className = 'ai-preset-copy';
      summary.textContent = `${preset.summary} 选中后会直接参与生成；如果你想继续手改提示词，可以点上面的按钮把预设内容写进文本框。推荐篇幅：${preset.recommendedLengthPreset}，推荐插图：${preset.recommendedIllustrationCount} 张。`;
      presetSummary.append(summary);
    };

    const applySelectedPreset = () => {
      const preset = readPreset(presetSelect?.value);

      if (!preset) {
        return;
      }

      setNamedFieldValue('customPrompt', preset.customPrompt || '');
      setNamedFieldValue('systemPrompt', preset.systemPrompt || '');
      setNamedFieldValue('lengthPreset', preset.recommendedLengthPreset || 'compact');
      setNamedFieldValue('illustrationCount', String(preset.recommendedIllustrationCount || 2));
      updatePresetSummary(preset.id);
      saveStoredConfig(buildStoredConfigSnapshot());
      setStatus(`已将「${preset.label}」预设写入提示词。`);
    };

    const setResultActions = (post) => {
      resultActions.innerHTML = '';

      if (!post) {
        return;
      }

      const editLink = document.createElement('a');
      editLink.className = 'button button-primary';
      editLink.href = post.adminUrl;
      editLink.textContent = '打开后台编辑';
      resultActions.append(editLink);

      if (post.publicUrl) {
        const publicLink = document.createElement('a');
        publicLink.className = 'button';
        publicLink.href = post.publicUrl;
        publicLink.target = '_blank';
        publicLink.rel = 'noreferrer';
        publicLink.textContent = '查看前台页面';
        resultActions.append(publicLink);
      }
    };

    const appendStreamOutput = (chunk) => {
      const current = streamOutput.textContent === EMPTY_STREAM_TEXT ? '' : streamOutput.textContent;
      streamOutput.textContent = `${current}${chunk}`;
      streamOutput.scrollTop = streamOutput.scrollHeight;
    };

    const resetResearchOutput = (enabled = false) => {
      if (!researchOutput) {
        return;
      }

      researchOutput.innerHTML = '';
      const placeholder = document.createElement('div');
      placeholder.className = 'ai-research-placeholder';
      placeholder.textContent = enabled ? '正在等待联网检索结果...' : EMPTY_RESEARCH_TEXT;
      researchOutput.append(placeholder);
    };

    const renderResearchOutput = ({ query, sources, message }) => {
      if (!researchOutput) {
        return;
      }

      researchOutput.innerHTML = '';

      const summary = document.createElement('div');
      summary.className = 'ai-research-summary';
      summary.textContent = message || (Array.isArray(sources) && sources.length ? `共整理 ${sources.length} 条资料。` : '没有可展示的资料。');
      researchOutput.append(summary);

      if (query) {
        const queryNode = document.createElement('div');
        queryNode.className = 'ai-research-query';
        queryNode.textContent = `检索词：${query}`;
        researchOutput.append(queryNode);
      }

      if (!Array.isArray(sources) || !sources.length) {
        return;
      }

      sources.forEach((source) => {
        const item = document.createElement('article');
        item.className = 'ai-research-item';

        const title = document.createElement('h3');
        title.className = 'ai-research-item-title';
        title.textContent = source.title || '未命名来源';
        item.append(title);

        if (source.url) {
          const link = document.createElement('a');
          link.className = 'ai-research-item-link';
          link.href = source.url;
          link.target = '_blank';
          link.rel = 'noreferrer';
          link.textContent = source.url;
          item.append(link);
        }

        if (source.snippet) {
          const snippet = document.createElement('p');
          snippet.className = 'ai-research-item-snippet';
          snippet.textContent = source.snippet;
          item.append(snippet);
        }

        researchOutput.append(item);
      });
    };

    const resetAssetsOutput = (enabled = false) => {
      if (!assetOutput) {
        return;
      }

      assetOutput.innerHTML = '';
      const placeholder = document.createElement('div');
      placeholder.className = 'ai-assets-placeholder';
      placeholder.textContent = enabled ? '正在等待自动配图...' : EMPTY_ASSET_TEXT;
      assetOutput.append(placeholder);
    };

    const appendAssetMeta = (container, text) => {
      if (!text) {
        return;
      }

      const node = document.createElement('p');
      node.className = 'ai-asset-meta';
      node.textContent = text;
      container.append(node);
    };

    const appendAssetLink = (container, text, href) => {
      if (!href) {
        return;
      }

      const link = document.createElement('a');
      link.className = 'button';
      link.href = href;
      link.target = '_blank';
      link.rel = 'noreferrer';
      link.textContent = text;
      container.append(link);
    };

    const renderAssetCard = ({ label, title, imageUrl, previewUrl, query, creator, license, sourceUrl, caption }) => {
      const card = document.createElement('article');
      card.className = 'ai-asset-card';

      const media = document.createElement('div');
      media.className = 'ai-asset-media';
      const image = document.createElement('img');
      image.src = previewUrl || imageUrl;
      image.alt = title || label;
      image.loading = 'lazy';
      media.append(image);
      card.append(media);

      const body = document.createElement('div');
      body.className = 'ai-asset-body';

      const eyebrow = document.createElement('div');
      eyebrow.className = 'ai-asset-eyebrow';
      eyebrow.textContent = label;
      body.append(eyebrow);

      const heading = document.createElement('h3');
      heading.className = 'ai-asset-title';
      heading.textContent = title || label;
      body.append(heading);

      appendAssetMeta(body, query ? `检索词：${query}` : '');
      appendAssetMeta(body, creator ? `作者：${creator}` : '');
      appendAssetMeta(body, license ? `许可：${license}` : '');

      if (caption) {
        const captionNode = document.createElement('p');
        captionNode.className = 'ai-asset-caption';
        captionNode.textContent = caption;
        body.append(captionNode);
      }

      const links = document.createElement('div');
      links.className = 'ai-asset-links';
      appendAssetLink(links, '查看图片', imageUrl);
      appendAssetLink(links, '来源页面', sourceUrl);

      if (links.childElementCount) {
        body.append(links);
      }

      card.append(body);
      return card;
    };

    const renderAssetsOutput = ({ message, cover, illustrations, plan }) => {
      if (!assetOutput) {
        return;
      }

      assetOutput.innerHTML = '';

      const summary = document.createElement('div');
      summary.className = 'ai-assets-summary';
      summary.textContent = message || '自动配图已完成。';
      assetOutput.append(summary);

      if (plan && (Array.isArray(plan.coverQueries) || Array.isArray(plan.illustrations))) {
        const planNode = document.createElement('div');
        planNode.className = 'ai-asset-plan';

        if (Array.isArray(plan.coverQueries) && plan.coverQueries.length) {
          const coverPlan = document.createElement('p');
          coverPlan.className = 'ai-asset-meta';
          coverPlan.textContent = `封面检索词：${plan.coverQueries.join(' / ')}`;
          planNode.append(coverPlan);
        }

        if (Array.isArray(plan.illustrations) && plan.illustrations.length) {
          const illustrationPlan = document.createElement('p');
          illustrationPlan.className = 'ai-asset-meta';
          illustrationPlan.textContent = `插图计划：${plan.illustrations.map((item) => `${item.heading} -> ${item.query}`).join('；')}`;
          planNode.append(illustrationPlan);
        }

        if (planNode.childElementCount) {
          assetOutput.append(planNode);
        }
      }

      const grid = document.createElement('div');
      grid.className = 'ai-asset-grid';

      if (cover?.url) {
        grid.append(renderAssetCard({
          label: cover.mode === 'manual' ? '手动封面' : '自动封面',
          title: cover.title || (cover.mode === 'manual' ? '当前封面' : '封面候选'),
          imageUrl: cover.url,
          previewUrl: cover.previewUrl,
          query: cover.query,
          creator: cover.creator,
          license: cover.license,
          sourceUrl: cover.sourceUrl,
        }));
      }

      if (Array.isArray(illustrations)) {
        illustrations.forEach((item, index) => {
          grid.append(renderAssetCard({
            label: `正文插图 ${index + 1}`,
            title: item.alt || item.heading || `正文插图 ${index + 1}`,
            imageUrl: item.imageUrl,
            previewUrl: item.previewUrl,
            query: item.query,
            creator: item.creator,
            license: item.license,
            sourceUrl: item.sourceUrl,
            caption: item.caption,
          }));
        });
      }

      if (!grid.childElementCount) {
        const placeholder = document.createElement('div');
        placeholder.className = 'ai-assets-placeholder';
        placeholder.textContent = message || EMPTY_ASSET_TEXT;
        assetOutput.append(placeholder);
        return;
      }

      assetOutput.append(grid);
    };

    const readEventStream = async (response, handlers) => {
      if (!response.body) {
        throw new Error('服务端没有返回可读取的流式内容。');
      }

      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();

        if (done) {
          break;
        }

        buffer += decoder.decode(value, { stream: true });
        const events = buffer.split(/\r?\n\r?\n/);
        buffer = events.pop() ?? '';

        events.forEach((eventText) => {
          const lines = eventText.split(/\r?\n/);
          const eventLine = lines.find((line) => line.startsWith('event:'));
          const dataLines = lines.filter((line) => line.startsWith('data:')).map((line) => line.slice(5).trim());

          if (!eventLine || !dataLines.length) {
            return;
          }

          const eventName = eventLine.slice(6).trim();
          const payload = JSON.parse(dataLines.join('\n'));
          const handler = handlers[eventName];

          if (handler) {
            handler(payload);
          }
        });
      }
    };

    const fillModels = (models) => {
      modelSelect.innerHTML = '';

      if (!Array.isArray(models) || !models.length) {
        const option = document.createElement('option');
        option.value = '';
        option.textContent = '没有拿到可用模型';
        modelSelect.append(option);
        return;
      }

      models.forEach((model, index) => {
        const option = document.createElement('option');
        option.value = model.id;
        option.textContent = model.id;
        option.selected = index === 0;
        modelSelect.append(option);
      });

      const storedConfig = loadStoredConfig();
      const matched = models.find((model) => model.id === storedConfig.model);

      if (matched) {
        modelSelect.value = matched.id;
      }
    };

    const restoreStoredConfig = () => {
      const stored = loadStoredConfig();

      if (presetSelect) {
        presetSelect.value = stored.presetId;
      }

      if (stored.baseUrl) {
        baseUrlInput.value = stored.baseUrl;
      }

      if (stored.apiKey) {
        apiKeyInput.value = stored.apiKey;
      }

      [
        ['customPrompt', stored.customPrompt],
        ['systemPrompt', stored.systemPrompt],
        ['webSearchQuery', stored.webSearchQuery],
        ['lengthPreset', stored.lengthPreset],
        ['illustrationCount', stored.illustrationCount],
      ].forEach(([name, value]) => {
        const field = readNamedField(name);
        if (field && 'value' in field) {
          field.value = value;
        }
      });

      [
        ['webSearchEnabled', stored.webSearchEnabled],
        ['autoCoverEnabled', stored.autoCoverEnabled],
        ['autoIllustrationsEnabled', stored.autoIllustrationsEnabled],
      ].forEach(([name, checked]) => {
        const field = readNamedField(name);
        if (field && 'checked' in field) {
          field.checked = checked;
        }
      });

      if (stored.baseUrl || stored.apiKey) {
        setStatus('已恢复上次保存的 AI 配置。');
      }

      updatePresetSummary(stored.presetId);
    };

    restoreStoredConfig();
    resetResearchOutput(readNamedCheckboxValue('webSearchEnabled'));
    resetAssetsOutput(readNamedCheckboxValue('autoCoverEnabled', true) || readNamedCheckboxValue('autoIllustrationsEnabled', true));

    clearConfigButton?.addEventListener('click', () => {
      clearStoredConfig();
      baseUrlInput.value = '';
      apiKeyInput.value = '';
      modelSelect.innerHTML = '<option value="">请先加载模型</option>';
      if (presetSelect) {
        presetSelect.value = DEFAULT_PRESET_ID;
      }

      [
        ['customPrompt', ''],
        ['systemPrompt', ''],
        ['webSearchQuery', ''],
        ['lengthPreset', 'compact'],
        ['illustrationCount', '2'],
      ].forEach(([name, value]) => {
        const field = readNamedField(name);
        if (field && 'value' in field) {
          field.value = value;
        }
      });

      [
        ['webSearchEnabled', false],
        ['autoCoverEnabled', true],
        ['autoIllustrationsEnabled', true],
        ['featured', false],
      ].forEach(([name, checked]) => {
        const field = readNamedField(name);
        if (field && 'checked' in field) {
          field.checked = checked;
        }
      });

      resetResearchOutput(false);
      resetAssetsOutput(true);
      updatePresetSummary(DEFAULT_PRESET_ID);
      setStatus('本地保存的 AI 配置已清空。');
    });

    loadModelsButton?.addEventListener('click', async () => {
      const baseUrl = baseUrlInput?.value?.trim();
      const apiKey = apiKeyInput?.value?.trim();

      if (!baseUrl || !apiKey) {
        setStatus('请先填写 Base URL 和 API Key。', true);
        return;
      }

      loadModelsButton.disabled = true;
      setStatus('正在获取模型列表...');

      try {
        const response = await fetch('/api/admin/ai/models', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ baseUrl, apiKey }),
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || '获取模型列表失败。');
        }

        fillModels(data.models || []);
        saveStoredConfig(buildStoredConfigSnapshot());
        setStatus(`已获取 ${data.models?.length ?? 0} 个模型。`);
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '获取模型列表失败。', true);
      } finally {
        loadModelsButton.disabled = false;
      }
    });

    form?.addEventListener('submit', async (submitEvent) => {
      submitEvent.preventDefault();

      const baseUrl = baseUrlInput?.value?.trim();
      const apiKey = apiKeyInput?.value?.trim();
      const model = modelSelect?.value?.trim();

      if (!baseUrl || !apiKey || !model) {
        setStatus('请先填写模型配置并加载可用模型。', true);
        return;
      }

      const formData = new FormData(form);
      const payload = {
        baseUrl,
        apiKey,
        model,
        presetId: String(formData.get('presetId') ?? DEFAULT_PRESET_ID),
        topic: String(formData.get('topic') ?? ''),
        keywords: String(formData.get('keywords') ?? ''),
        audience: String(formData.get('audience') ?? ''),
        requirements: String(formData.get('requirements') ?? ''),
        customPrompt: String(formData.get('customPrompt') ?? ''),
        systemPrompt: String(formData.get('systemPrompt') ?? ''),
        lengthPreset: String(formData.get('lengthPreset') ?? 'compact'),
        webSearchEnabled: formData.get('webSearchEnabled') === 'on',
        webSearchQuery: String(formData.get('webSearchQuery') ?? ''),
        cover: String(formData.get('cover') ?? ''),
        autoCoverEnabled: formData.get('autoCoverEnabled') === 'on',
        autoIllustrationsEnabled: formData.get('autoIllustrationsEnabled') === 'on',
        illustrationCount: Number(formData.get('illustrationCount') ?? 2),
        status: String(formData.get('status') ?? 'draft'),
        featured: formData.get('featured') === 'on',
      };

      saveStoredConfig(buildStoredConfigSnapshot());

      generateButton.disabled = true;
      resultActions.innerHTML = '';
      streamOutput.textContent = EMPTY_STREAM_TEXT;
      resetResearchOutput(payload.webSearchEnabled);
      resetAssetsOutput(payload.autoCoverEnabled || payload.autoIllustrationsEnabled);
      setStatus('正在启动 AI 写作...');

      try {
        const response = await fetch('/api/admin/ai/generate', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'text/event-stream',
          },
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          const data = await response.json();
          throw new Error(data.message || 'AI 写作失败。');
        }

        await readEventStream(response, {
          status: (data) => {
            setStatus(data.message || 'AI 正在写作...');
          },
          research: (data) => {
            renderResearchOutput(data);
            if (data.message) {
              setStatus(data.message);
            }
          },
          assets: (data) => {
            renderAssetsOutput(data);
            if (data.message) {
              setStatus(data.message);
            }
          },
          content: (data) => {
            appendStreamOutput(data.chunk || '');
          },
          done: (data) => {
            if (data.rawText) {
              streamOutput.textContent = data.rawText;
            }

            setStatus(data.message || 'AI 写作完成。');
            setResultActions(data.post || null);
          },
          error: (data) => {
            if (data.rawText) {
              streamOutput.textContent = data.rawText;
            }

            setStatus(data.message || 'AI 写作失败，请稍后再试。', true);
          },
        });
      } catch (error) {
        setStatus(error instanceof Error ? error.message : 'AI 写作失败，请稍后再试。', true);
      } finally {
        generateButton.disabled = false;
      }
    });

    modelSelect?.addEventListener('change', () => {
      saveStoredConfig(buildStoredConfigSnapshot());
    });

    presetSelect?.addEventListener('change', () => {
      updatePresetSummary(presetSelect.value);
      saveStoredConfig(buildStoredConfigSnapshot());
    });

    applyPresetButton?.addEventListener('click', () => {
      applySelectedPreset();
    });

    baseUrlInput?.addEventListener('change', () => {
      saveStoredConfig(buildStoredConfigSnapshot());
    });

    apiKeyInput?.addEventListener('change', () => {
      saveStoredConfig(buildStoredConfigSnapshot());
    });

    form?.addEventListener('change', (changeEvent) => {
      saveStoredConfig(buildStoredConfigSnapshot());

      if (changeEvent?.target?.name === 'webSearchEnabled') {
        resetResearchOutput(readNamedCheckboxValue('webSearchEnabled'));
      }

      if (changeEvent?.target?.name === 'autoCoverEnabled' || changeEvent?.target?.name === 'autoIllustrationsEnabled') {
        resetAssetsOutput(readNamedCheckboxValue('autoCoverEnabled', true) || readNamedCheckboxValue('autoIllustrationsEnabled', true));
      }
    });
  </script>
</AdminLayout>
