---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { ensureAnalyticsSchema, getAnalyticsSummary } from '../../lib/analytics/repository';
import { isAdminAuthenticated } from '../../lib/auth/guards';
import { getLearningTracks } from '../../lib/learning/repository';
import { getNovelChapterPostIds, getNovelProjects } from '../../lib/novels/repository';
import { getAdminPosts } from '../../lib/posts/repository';

const authenticated = await isAdminAuthenticated(Astro.cookies, Astro.locals.runtime?.env);

if (!authenticated) {
  return Astro.redirect('/admin/login');
}

const db = Astro.locals.runtime?.env?.DB;

const [posts, novelChapterPostIds, novelProjects, learningTracks] = db
  ? await Promise.all([
    getAdminPosts(db),
    getNovelChapterPostIds(db),
    getNovelProjects(db),
    getLearningTracks(db),
  ])
  : [[], [], [], []];

const chapterPostIdSet = new Set(novelChapterPostIds);
const standalonePosts = posts.filter((post) => !chapterPostIdSet.has(post.id));
const novelProjectCount = novelProjects.length;
const novelChapterCount = novelProjects.reduce((total, project) => total + project.chaptersCount, 0);
const learningTrackCount = learningTracks.length;
const draftCount = standalonePosts.filter((post) => post.status === 'draft').length;
const publishedCount = standalonePosts.filter((post) => post.status === 'published').length;

let analyticsUnavailable = false;
let analyticsSummary = {
  totalViews: 0,
  uniqueVisitors: 0,
  articleViews: 0,
  trackedCountries: 0,
};

try {
  if (db) {
    await ensureAnalyticsSchema(db);
    analyticsSummary = await getAnalyticsSummary(db);
  } else {
    analyticsUnavailable = true;
  }
} catch (error) {
  analyticsUnavailable = true;
  console.error('Failed to load admin overview analytics summary', error);
}
---

<AdminLayout title="后台概览" description="从这里进入博客、小说、学习专题、统计和 AI 配置。">
  <section class="grid four">
    <article class="content-card">
      <h3>博客文章</h3>
      <p class="admin-stat-value">{standalonePosts.length}</p>
    </article>
    <article class="content-card">
      <h3>博客草稿</h3>
      <p class="admin-stat-value">{draftCount}</p>
    </article>
    <article class="content-card">
      <h3>小说项目</h3>
      <p class="admin-stat-value">{novelProjectCount}</p>
    </article>
    <article class="content-card">
      <h3>学习专题</h3>
      <p class="admin-stat-value">{learningTrackCount}</p>
    </article>
  </section>

  <section class="grid four" style="padding-top: 1.25rem;">
    <article class="content-card">
      <h3>已发布博客</h3>
      <p class="admin-stat-value">{publishedCount}</p>
    </article>
    <article class="content-card">
      <h3>小说章节</h3>
      <p class="admin-stat-value">{novelChapterCount}</p>
    </article>
    <article class="content-card">
      <h3>总访问量</h3>
      <p class="admin-stat-value">{analyticsSummary.totalViews}</p>
    </article>
    <article class="content-card">
      <h3>独立访客</h3>
      <p class="admin-stat-value">{analyticsSummary.uniqueVisitors}</p>
    </article>
  </section>

  {analyticsUnavailable ? (
    <section class="section" style="padding-bottom: 0;">
      <div class="empty-state">
        当前统计数据不可用。通常是本地开发环境没有 Cloudflare 运行时绑定，或者统计表还没有初始化。
      </div>
    </section>
  ) : null}

  <section class="section" style="padding-bottom: 0;">
    <div class="archive-toolbar">
      <div>
        <h2 class="section-title">常用入口</h2>
        <p class="section-description">直接进入你最常操作的几个后台模块。</p>
      </div>
      <div class="hero-actions">
        <a class="button button-primary" href="/admin/posts/new">新建博客</a>
        <a class="button" href="/admin/posts">管理博客</a>
        <a class="button" href="/admin/novels">管理小说</a>
        <a class="button" href="/admin/learning">管理学习</a>
        <a class="button" href="/admin/stats">查看统计</a>
        <a class="button" href="/admin/ai">AI 配置</a>
      </div>
    </div>
  </section>
</AdminLayout>
