---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAdminAuthConfig } from '../../lib/auth/config';
import { isAdminAuthenticated } from '../../lib/auth/guards';

const runtimeEnv = Astro.locals.runtime?.env;
const authConfig = getAdminAuthConfig(runtimeEnv);
const authenticated = await isAdminAuthenticated(Astro.cookies, runtimeEnv);

if (authenticated) {
  return Astro.redirect('/admin/posts');
}

const error = Astro.url.searchParams.get('error');
const alertMessage =
  !authConfig.isConfigured || error === 'config'
    ? '后台配置不完整，请检查 Cloudflare 运行时环境变量并重新部署后再试。'
    : error
      ? '密码错误，请重试。'
      : null;
---

<BaseLayout title="后台登录 | AJC 博客" description="登录 AJC 博客后台">
  <section class="section">
    <div class="container" style="max-width: 560px;">
      <div class="card" style="padding: 2rem;">
        <p class="eyebrow">AJC Admin</p>
        <h1 style="margin-top: 0;">登录后台</h1>
        <p class="page-intro">输入管理员密码后即可创建、编辑和发布文章。</p>
        <form class="admin-form" action="/api/admin/login" method="post" style="margin-top: 1.5rem;">
          {alertMessage ? <div class="admin-alert">{alertMessage}</div> : null}
          <label class="admin-field">
            <span>管理员密码</span>
            <input class="search-input admin-input-rect" type="password" name="password" autocomplete="current-password" required />
          </label>
          <div class="hero-actions">
            <button class="button button-primary" type="submit">登录</button>
            <a class="button" href="/">返回首页</a>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
